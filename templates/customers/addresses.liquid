<div style="background-color: #0c0a09; min-height: 80vh; padding: 64px 24px; color: #fff;">
  <div style="max-width: 800px; margin: 0 auto;">
    
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 24px;">
      <div>
        <a href="{{ routes.account_url }}" style="color: #888; text-decoration: none; font-size: 14px; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 16px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Back to Account
        </a>
        <h1 style="font-family: 'Outfit', serif; font-size: 42px; margin: 0;">Addresses</h1>
      </div>
      <button onclick="alert('In a full setup, this opens the Add Address form.')" style="background: #C5A880; color: #fff; border: none; padding: 12px 24px; border-radius: 50px; font-weight: bold; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; cursor: pointer;">
        Add New Address
      </button>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
      {% for address in customer.addresses %}
        <div style="background: #131110; padding: 32px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); position: relative;">
          {% if address == customer.default_address %}
            <span style="position: absolute; top: 32px; right: 32px; background: rgba(255,255,255,0.1); color: #fff; padding: 4px 12px; border-radius: 50px; font-size: 10px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px;">Default</span>
          {% endif %}
          
          <h3 style="font-size: 18px; margin-bottom: 16px; font-weight: 700;">{{ address.first_name }} {{ address.last_name }}</h3>
          <p style="color: #aaa; font-size: 14px; line-height: 1.6; margin-bottom: 24px;">
            {{ address.address1 }}<br>
            {% if address.address2 != "" %}
              {{ address.address2 }}<br>
            {% endif %}
            {{ address.city }}, {% if address.province_code %}{{ address.province_code }}, {% endif %}{{ address.country }}<br>
            {{ address.zip }}
          </p>
          
          <div style="display: flex; gap: 16px;">
            <button style="background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.2); padding: 8px 16px; border-radius: 50px; font-size: 12px; cursor: pointer;">Edit</button>
            <button style="background: transparent; color: #dc3545; border: 1px solid rgba(220,53,69,0.2); padding: 8px 16px; border-radius: 50px; font-size: 12px; cursor: pointer;">Delete</button>
          </div>
        </div>
      {% endform %}
    </div>

  </div>
</div>

<style>
  @media (max-width: 700px) {
    div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
