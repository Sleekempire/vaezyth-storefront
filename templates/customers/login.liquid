{% comment %}
  Vaezyth – Customer Login Page
{% endcomment %}

<style>
  .auth-page {
    background: #0c0a09;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 24px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  /* Decorative blurred gradient orbs */
  .auth-page::before {
    content: '';
    position: fixed;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(197,168,128,0.08) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    pointer-events: none;
  }

  .auth-page::after {
    content: '';
    position: fixed;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(197,168,128,0.05) 0%, transparent 70%);
    bottom: -80px;
    left: -80px;
    pointer-events: none;
  }

  .auth-card {
    width: 100%;
    max-width: 460px;
    background: #131110;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 28px;
    padding: 52px 48px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6);
    position: relative;
    z-index: 1;
  }

  .auth-logo {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #C5A880;
    text-align: center;
    margin-bottom: 32px;
  }

  .auth-title {
    font-family: 'Outfit', sans-serif;
    font-size: 32px;
    font-weight: 700;
    text-align: center;
    margin: 0 0 8px;
    letter-spacing: -0.5px;
  }

  .auth-subtitle {
    text-align: center;
    color: #888;
    font-size: 14px;
    margin: 0 0 36px;
  }

  .auth-error {
    background: rgba(220,53,69,0.1);
    border: 1px solid rgba(220,53,69,0.2);
    color: #ff6b7a;
    padding: 12px 16px;
    border-radius: 12px;
    margin-bottom: 24px;
    font-size: 13px;
    line-height: 1.5;
  }

  .auth-field {
    width: 100%;
    padding: 15px 18px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    color: #fff;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .auth-field:focus {
    border-color: #C5A880;
  }

  .auth-field::placeholder { color: #555; }

  .field-wrap {
    margin-bottom: 16px;
  }

  .field-label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #888;
    margin-bottom: 8px;
  }

  .forgot-link {
    text-align: right;
    margin-top: 6px;
  }

  .forgot-link a {
    color: #C5A880;
    font-size: 12px;
    text-decoration: none;
    font-weight: 600;
  }

  .btn-auth {
    width: 100%;
    padding: 16px;
    background: #fff;
    color: #0c0a09;
    border: none;
    border-radius: 50px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    margin-top: 24px;
  }

  .btn-auth:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .auth-divider {
    text-align: center;
    margin: 28px 0;
    position: relative;
    color: #444;
    font-size: 12px;
  }

  .auth-divider::before, .auth-divider::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 42%;
    height: 1px;
    background: rgba(255,255,255,0.07);
  }

  .auth-divider::before { left: 0; }
  .auth-divider::after { right: 0; }

  .auth-switch {
    text-align: center;
    font-size: 14px;
    color: #888;
  }

  .auth-switch a {
    color: #fff;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.3);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }

  .auth-switch a:hover { border-color: #fff; }

  @media (max-width: 500px) {
    .auth-card {
      padding: 36px 24px;
    }
  }
</style>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">VAEZYTH</div>

    <!-- Login Form -->
    <div id="CustomerLoginForm">
      <h1 class="auth-title">Welcome Back</h1>
      <p class="auth-subtitle">Sign in to your account to continue.</p>

      {% form 'customer_login' %}
        {% if form.errors %}
          <div class="auth-error">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="field-wrap">
          <label for="CustomerEmail" class="field-label">Email</label>
          <input type="email" name="customer[email]" id="CustomerEmail" class="auth-field" placeholder="you@email.com" required autocorrect="off" autocapitalize="off" value="{{ form.email }}">
        </div>

        {% if form.password_needed %}
        <div class="field-wrap">
          <label for="CustomerPassword" class="field-label">Password</label>
          <input type="password" name="customer[password]" id="CustomerPassword" class="auth-field" placeholder="••••••••" required>
          <div class="forgot-link">
            <a href="#recover" onclick="showRecover(); return false;">Forgot password?</a>
          </div>
        </div>
        {% endif %}

        <button type="submit" class="btn-auth">Sign In</button>
      {% endform %}

      <div class="auth-divider">or</div>

      <div class="auth-switch">
        Don't have an account? <a href="{{ routes.account_register_url }}">Create one</a>
      </div>
    </div>

    <!-- Recover Password Form (hidden by default) -->
    <div id="RecoverPasswordForm" style="display: none;">
      <h1 class="auth-title">Reset Password</h1>
      <p class="auth-subtitle">Enter your email and we'll send a reset link.</p>

      {% form 'recover_customer_password' %}
        {% if form.posted_successfully? %}
          <div style="background: rgba(40,167,69,0.1); border: 1px solid rgba(40,167,69,0.2); color: #6fcf97; padding: 14px; border-radius: 12px; font-size: 13px; text-align: center; margin-bottom: 24px;">
            ✓ Check your email for a reset link.
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="auth-error">{{ form.errors | default_errors }}</div>
        {% endif %}

        <div class="field-wrap">
          <label for="RecoverEmail" class="field-label">Email</label>
          <input type="email" name="email" id="RecoverEmail" class="auth-field" placeholder="you@email.com" required autocorrect="off" autocapitalize="off">
        </div>

        <button type="submit" class="btn-auth">Send Reset Link</button>
      {% endform %}

      <div class="auth-divider" style="margin-top: 24px;"></div>

      <div class="auth-switch">
        <a href="#" onclick="showLogin(); return false;">← Back to sign in</a>
      </div>
    </div>

  </div>
</div>

<script>
  function showRecover() {
    document.getElementById('CustomerLoginForm').style.display = 'none';
    document.getElementById('RecoverPasswordForm').style.display = 'block';
  }

  function showLogin() {
    document.getElementById('RecoverPasswordForm').style.display = 'none';
    document.getElementById('CustomerLoginForm').style.display = 'block';
  }

  if (window.location.hash === '#recover') showRecover();
</script>
