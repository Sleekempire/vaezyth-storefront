<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ page_title }}</title>
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Outfit:wght@300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&display=swap');
    </style>
  </head>
  <body class="template-{{ template | handleize }}">
    {% section 'header' %}
    
    <main role="main" id="MainContent" class="app-container fade-in">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}
    
    {% include 'cart-drawer' %}
    
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
