<div class="brand-logo-group" style="cursor: pointer; flex: 1; display: flex; align-items: center;">
  <div class="mobile-menu-toggle" style="display: none; cursor: pointer; color: #ffffff; margin-right: 16px; padding: 8px;">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
  </div>
  <a href="/" class="brand-logo-link" style="text-decoration: none; display: inline-block;">
    {% if settings.logo != blank %}
      <img src="{{ settings.logo | img_url: 'master' }}" alt="{{ shop.name }}" style="max-height: 40px; width: auto; object-fit: contain;">
    {% else %}
      <span class="brand-logo-text" style="font-family: 'Outfit', sans-serif; font-size: 28px; font-weight: 800; letter-spacing: -1px; color: #ffffff;">VAEZYTH</span>
    {% endif %}
  </a>
</div>
<div class="nav-links" id="NavLinks" style="display: flex; gap: 40px; align-items: center;">
  <a href="/" class="nav-link" style="text-decoration: none; color: #ffffff; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;">Home</a>
  <a href="/collections/all" class="nav-link" style="text-decoration: none; color: #ffffff; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;">Catalog</a>
  <a href="/pages/contact" class="nav-link" style="text-decoration: none; color: #ffffff; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;">Contact</a>
</div>
<div class="nav-actions" style="display: flex; gap: 16px; flex: 1; justify-content: flex-end;">
  <button class="btn-nav-action cart-toggle-btn" style="position: relative; background: transparent; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #ffffff; transition: color 0.3s; padding: 8px;">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
    <span class="badge-cart-count" id="cart-item-count" style="position: absolute; top: -4px; right: -8px; background: #C5A880; color: #fff; border-radius: 50%; font-size: 10px; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; font-weight: bold;">0</span>
  </button>
</div>
