{% assign target_collection = collections[section.settings.collection] %}
{% assign products = target_collection.products %}

<style>
  .cl-section {
    padding: 32px 0 40px;
    background: #f5f2ee;
  }
  .cl-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    box-sizing: border-box;
  }
  .cl-header {
    text-align: center;
    max-width: 520px;
    margin: 0 auto 20px;
  }
  .cl-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #8C7A5D;
    margin: 0 0 6px;
  }
  .cl-desc {
    font-size: 13px;
    color: #666;
    line-height: 1.5;
    margin: 6px 0 0;
  }

  /* Bento Grid */
  .cl-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 16px;
    align-items: stretch;
  }

  /* Left Tall Card — Collars & Leashes */
  .cl-left-card {
    background: #fff;
    border-radius: 24px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .cl-left-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
  }
  .cl-card-header {
    margin-bottom: 16px;
  }
  .cl-card-title {
    font-family: 'Outfit', sans-serif;
    font-size: 26px;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0 0 8px;
    letter-spacing: -0.5px;
  }
  .cl-card-text {
    font-size: 13px;
    color: #666;
    line-height: 1.4;
    margin: 0;
  }
  .cl-left-img-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: #f0ece6;
  }
  .cl-left-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cl-arrow-btn {
    position: absolute;
    bottom: 12px;
    right: 12px;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #4A5D4E;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    transition: background 0.2s;
  }
  .cl-left-card:hover .cl-arrow-btn {
    background: #3e4f42;
  }

  /* Right Column Layout */
  .cl-right-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Right Top Wide Card — Beds & Mats */
  .cl-wide-card {
    background: #f0ebe4;
    border-radius: 24px;
    padding: 24px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  }
  .cl-wide-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
  }
  .cl-wide-info {
    flex: 1;
  }
  .cl-badge {
    display: inline-block;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 50px;
    background: #fff;
    color: #666;
    margin-bottom: 8px;
    border: 1px solid rgba(0,0,0,0.05);
  }
  .cl-wide-title {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 6px;
  }
  .cl-wide-text {
    font-size: 12px;
    color: #666;
    line-height: 1.4;
    margin: 0;
  }
  .cl-wide-img-wrapper {
    width: 120px;
    height: 120px;
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    flex-shrink: 0;
  }
  .cl-wide-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Right Bottom Row split */
  .cl-split-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    flex: 1;
  }

  /* Pink Card — Bowls & Feeding */
  .cl-pink-card {
    background: #f7ebe3;
    border-radius: 24px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 12px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .cl-pink-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
  }
  .cl-icon-leaf {
    width: 28px;
    height: 28px;
    color: #8C7A5D;
  }
  .cl-split-title {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
  }
  .cl-split-text {
    font-size: 12px;
    color: #666;
    line-height: 1.4;
    margin: 0;
  }

  /* Green Card — Accessories */
  .cl-green-card {
    background: #3a4b3d;
    color: #fff;
    border-radius: 24px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .cl-green-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.1);
  }
  .cl-green-title {
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 6px;
    color: #fff;
  }
  .cl-green-text {
    font-size: 12px;
    color: #cbd5e1;
    line-height: 1.4;
    margin: 0 0 12px;
  }
  .cl-green-line {
    width: 40px;
    height: 2px;
    background: rgba(255,255,255,0.3);
  }

  @media (max-width: 900px) {
    .cl-section {
      padding: 28px 0 32px;
    }
    .cl-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .cl-split-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .cl-left-card, .cl-wide-card, .cl-pink-card, .cl-green-card {
      padding: 20px;
      border-radius: 20px;
    }
    .cl-card-title {
      font-size: 22px;
    }
    .cl-wide-card {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 12px;
    }
    .cl-wide-img-wrapper {
      width: 100%;
      height: 160px;
    }
  }
</style>

<div class="cl-section">
  <div class="cl-inner">

    <div class="cl-header">
      <span class="cl-label">Curated Living</span>
      <p class="cl-desc">Handpicked collections designed to integrate seamlessly into your home while providing unrivaled pet comfort.</p>
    </div>

    <div class="cl-grid">
      <!-- Left Card — Collars & Leashes -->
      <a href="/collections/collars-leashes" class="cl-left-card">
        <div class="cl-card-header">
          <h3 class="cl-card-title">Collars & Leashes</h3>
          <p class="cl-card-text">Premium walking gear built for comfort and durability.</p>
        </div>
        <div class="cl-left-img-wrapper">
          {% if products[0].featured_image != blank %}
            <img src="{{ products[0].featured_image | img_url: '800x' }}" alt="Collars & Leashes" loading="lazy" />
          {% else %}
            <div style="width:100%;height:100%;background:#e8e4de;display:flex;align-items:center;justify-content:center;color:#999;font-size:14px;">Collars & Leashes</div>
          {% endif %}
          <div class="cl-arrow-btn">↗</div>
        </div>
      </a>

      <!-- Right Column -->
      <div class="cl-right-col">
        <!-- Right Top Wide Card — Beds & Mats -->
        <a href="/collections/beds-mats" class="cl-wide-card">
          <div class="cl-wide-info">
            <span class="cl-badge">Comfort Range</span>
            <h3 class="cl-wide-title">Beds & Mats</h3>
            <p class="cl-wide-text">Cozy resting spots designed for ultimate relaxation.</p>
          </div>
          <div class="cl-wide-img-wrapper">
            {% if products[1].featured_image != blank %}
              <img src="{{ products[1].featured_image | img_url: '600x' }}" alt="Beds & Mats" loading="lazy" />
            {% else %}
              <div style="width:100%;height:100%;background:#e8e4de;display:flex;align-items:center;justify-content:center;color:#999;font-size:13px;">Beds & Mats</div>
            {% endif %}
          </div>
        </a>

        <!-- Right Bottom split -->
        <div class="cl-split-row">
          <!-- Pink Card — Bowls & Feeding -->
          <a href="/collections/bowls-feeding" class="cl-pink-card">
            <svg class="cl-icon-leaf" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 8h1a4 4 0 0 1 0 8h-1"/>
              <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
              <line x1="6" y1="1" x2="6" y2="4"/>
              <line x1="10" y1="1" x2="10" y2="4"/>
              <line x1="14" y1="1" x2="14" y2="4"/>
            </svg>
            <h3 class="cl-split-title">Bowls & Feeding</h3>
            <p class="cl-split-text">Stylish feeding solutions for every mealtime.</p>
          </a>

          <!-- Green Card — Accessories -->
          <a href="/collections/accessories" class="cl-green-card">
            <div>
              <h3 class="cl-green-title">Accessories</h3>
              <p class="cl-green-text">Fun extras to elevate your pet's lifestyle.</p>
            </div>
            <div class="cl-green-line"></div>
          </a>
        </div>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Featured Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Grid"
    }
  ]
}
{% endschema %}
