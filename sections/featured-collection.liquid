{% assign target_collection = collections[section.settings.collection] %}
{% assign products = target_collection.products %}

<style>
  .cl-section {
    padding: 60px 0;
    background: #f5f2ee;
  }
  .cl-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    box-sizing: border-box;
  }
  .cl-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 40px;
  }
  .cl-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #8C7A5D;
    margin: 0 0 8px;
  }
  .cl-desc {
    font-size: 13px;
    color: #666;
    line-height: 1.6;
    margin: 8px 0 0;
  }
  
  /* Bento Grid */
  .cl-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 24px;
    align-items: stretch;
  }
  
  /* Left Tall Card */
  .cl-left-card {
    background: #fff;
    border-radius: 32px;
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .cl-left-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
  }
  .cl-card-header {
    margin-bottom: 24px;
  }
  .cl-card-title {
    font-family: 'Outfit', sans-serif;
    font-size: 32px;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0 0 12px;
    letter-spacing: -0.5px;
  }
  .cl-card-text {
    font-size: 14px;
    color: #666;
    line-height: 1.5;
    margin: 0;
  }
  .cl-left-img-wrapper {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: #f8f8f8;
  }
  .cl-left-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cl-arrow-btn {
    position: absolute;
    bottom: 16px;
    right: 16px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #4A5D4E;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    transition: background 0.2s;
  }
  .cl-left-card:hover .cl-arrow-btn {
    background: #3e4f42;
  }

  /* Right Column Layout */
  .cl-right-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  
  /* Right Top Wide Card */
  .cl-wide-card {
    background: #f0ebe4;
    border-radius: 32px;
    padding: 32px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  }
  .cl-wide-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
  }
  .cl-wide-info {
    flex: 1;
  }
  .cl-badge {
    display: inline-block;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 50px;
    background: #fff;
    color: #666;
    margin-bottom: 12px;
    border: 1px solid rgba(0,0,0,0.05);
  }
  .cl-wide-title {
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 8px;
  }
  .cl-wide-text {
    font-size: 13px;
    color: #666;
    line-height: 1.5;
    margin: 0;
  }
  .cl-wide-img-wrapper {
    width: 140px;
    height: 140px;
    border-radius: 20px;
    overflow: hidden;
    background: #fff;
    flex-shrink: 0;
  }
  .cl-wide-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Right Bottom Row split */
  .cl-split-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    flex: 1;
  }
  
  /* Pink Card */
  .cl-pink-card {
    background: #f7ebe3;
    border-radius: 32px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .cl-pink-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
  }
  .cl-icon-leaf {
    width: 32px;
    height: 32px;
    color: #8C7A5D;
  }
  .cl-split-title {
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
  }
  .cl-split-text {
    font-size: 13px;
    color: #666;
    line-height: 1.5;
    margin: 0;
  }

  /* Green Card */
  .cl-green-card {
    background: #3a4b3d;
    color: #fff;
    border-radius: 32px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .cl-green-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.1);
  }
  .cl-green-title {
    font-family: 'Outfit', sans-serif;
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 8px;
    color: #fff;
  }
  .cl-green-text {
    font-size: 13px;
    color: #cbd5e1;
    line-height: 1.5;
    margin: 0 0 16px;
  }
  .cl-green-line {
    width: 40px;
    height: 2px;
    background: rgba(255,255,255,0.3);
  }

  @media (max-width: 900px) {
    .cl-section {
      padding: 40px 0;
    }
    .cl-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .cl-split-row {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .cl-left-card, .cl-wide-card, .cl-pink-card, .cl-green-card {
      padding: 24px;
      border-radius: 24px;
    }
    .cl-card-title {
      font-size: 24px;
    }
    .cl-wide-card {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 16px;
    }
    .cl-wide-img-wrapper {
      width: 100%;
      height: 180px;
    }
  }
</style>

<div class="cl-section">
  <div class="cl-inner">
    
    <div class="cl-header">
      <span class="cl-label">Curated Living</span>
      <h2 style="font-family: 'Outfit', sans-serif; font-size: 32px; font-weight: 600; color: #1a1a1a; margin: 0;">{{ section.settings.title }}</h2>
      <p class="cl-desc">Handpicked collections designed to integrate seamlessly into your home's architecture while providing unrivaled pet comfort.</p>
    </div>

    <div class="cl-grid">
      <!-- Left Card (Sage Series) -->
      {% assign product_left = products[0] %}
      <a href="{{ product_left.url | default: '#' }}" class="cl-left-card">
        <div class="cl-card-header">
          <h3 class="cl-card-title">The Sage Series</h3>
          <p class="cl-card-text">Earthy tones and calming textures for the peaceful pup.</p>
        </div>
        <div class="cl-left-img-wrapper">
          {% if product_left.featured_image != blank %}
            <img src="{{ product_left.featured_image | img_url: '800x' }}" alt="{{ product_left.title | escape }}" loading="lazy" />
          {% else %}
            <img src="{{ 'pet_bed_1783288663556.png' | asset_url }}" alt="Sage Series Bed" loading="lazy" />
          {% endif %}
          <div class="cl-arrow-btn">↗</div>
        </div>
      </a>

      <!-- Right Column -->
      <div class="cl-right-col">
        <!-- Right Top Wide Card (Smart Care) -->
        {% assign product_wide = products[1] %}
        <a href="{{ product_wide.url | default: '#' }}" class="cl-wide-card">
          <div class="cl-wide-info">
            <span class="cl-badge">Tech-Enabled</span>
            <h3 class="cl-wide-title">Smart Care</h3>
            <p class="cl-wide-text">Automated solutions for busy modern families.</p>
          </div>
          <div class="cl-wide-img-wrapper">
            {% if product_wide.featured_image != blank %}
              <img src="{{ product_wide.featured_image | img_url: '600x' }}" alt="{{ product_wide.title | escape }}" loading="lazy" />
            {% else %}
              <img src="{{ 'pet_feeder_1783288672520.png' | asset_url }}" alt="Smart Care Feeder" loading="lazy" />
            {% endif %}
          </div>
        </a>

        <!-- Right Bottom split -->
        <div class="cl-split-row">
          <!-- Pink Card (Sustainable) -->
          {% assign product_pink = products[2] %}
          <a href="{{ product_pink.url | default: '/collections/all' }}" class="cl-pink-card">
            <svg class="cl-icon-leaf" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 22c1.25-6.7 5.85-11.75 12.35-13M12.35 9c2.8 1.45 4.5 4.5 4.5 7.5 0 2.2-1.8 4-4 4-2.5 0-4.65-2-4.65-4.5 0-3.3 3.65-7 4.15-7z"/>
              <path d="M12.35 9c2.5-4 7-6 9.65-7-1.25 5.5-3.3 9-6.3 11"/>
            </svg>
            <h3 class="cl-split-title">Sustainable</h3>
            <p class="cl-split-text">100% recycled materials used across this entire range.</p>
          </a>

          <!-- Green Card (Travel Pro) -->
          {% assign product_green = products[3] %}
          <a href="{{ product_green.url | default: '/collections/all' }}" class="cl-green-card">
            <div>
              <h3 class="cl-green-title">Travel Pro</h3>
              <p class="cl-green-text">Durability that survives every adventure.</p>
            </div>
            <div class="cl-green-line"></div>
          </a>
        </div>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Featured Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Grid"
    }
  ]
}
{% endschema %}
