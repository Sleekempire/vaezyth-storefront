<div class="section-title-wrapper" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
  <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 32px; font-style: italic; font-weight: normal;">{{ section.settings.title }}</h3>
  <a href="{{ collections[section.settings.collection].url }}" style="background: transparent; border: 1px solid #ddd; padding: 8px 24px; border-radius: 50px; font-size: 10px; font-weight: bold; cursor: pointer; text-decoration: none; color: #000;">
    SHOP COLLECTION ↗
  </a>
</div>

<div class="products-grid" style="grid-template-columns: repeat(3, 1fr);">
  {% assign target_collection = collections[section.settings.collection] %}
  {% for product in target_collection.products limit: 3 %}
    <div class="product-card luxury-card vertical-dark-card" style="background: #1c1917; color: #fff; border-radius: 16px; padding: 24px;">
      <a href="{{ product.url }}" style="text-decoration: none; color: inherit;">
        <div class="luxury-card-media" style="background: #fff; border-radius: 12px; height: 200px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
          <img src="{{ product.featured_image | img_url: 'large' }}" alt="{{ product.title }}" style="max-height: 160px; object-fit: contain;" />
        </div>
        <div class="product-card-title" style="color: #fff; font-size: 16px;">{{ product.title }}</div>
        <div class="product-card-price-row" style="margin-top: auto;">
          <span class="product-card-price" style="color: #fff;">{{ product.price | money }}</span>
        </div>
      </a>
    </div>
  {% else %}
    <div class="product-card luxury-card vertical-dark-card" style="background: #1c1917; color: #fff; border-radius: 16px; padding: 24px;">
      <div class="luxury-card-media" style="background: #fff; border-radius: 12px; height: 200px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
        <img src="{{ 'bottle_1.jpg' | asset_url }}" style="max-height: 160px; object-fit: contain;" />
      </div>
      <div class="product-card-title" style="color: #fff; font-size: 16px;">Vaezyth Travel Bottle</div>
      <div class="product-card-price-row" style="margin-top: auto;">
        <span class="product-card-price" style="color: #fff;">£18.99</span>
      </div>
    </div>
    <div class="product-card luxury-card vertical-dark-card" style="background: #1c1917; color: #fff; border-radius: 16px; padding: 24px;">
      <div class="luxury-card-media" style="background: #fff; border-radius: 12px; height: 200px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
        <img src="{{ 'mat_1.jpg' | asset_url }}" style="max-height: 160px; object-fit: contain; mix-blend-mode: multiply;" />
      </div>
      <div class="product-card-title" style="color: #fff; font-size: 16px;">Luxury Litter Mat</div>
      <div class="product-card-price-row" style="margin-top: auto;">
        <span class="product-card-price" style="color: #fff;">£32.00</span>
      </div>
    </div>
    <div class="product-card luxury-card vertical-dark-card" style="background: #1c1917; color: #fff; border-radius: 16px; padding: 24px;">
      <div class="luxury-card-media" style="background: #fff; border-radius: 12px; height: 200px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
        <img src="{{ 'leash_1.jpg' | asset_url }}" style="max-height: 160px; object-fit: contain;" />
      </div>
      <div class="product-card-title" style="color: #fff; font-size: 16px;">Premium Retractable Leash</div>
      <div class="product-card-price-row" style="margin-top: auto;">
        <span class="product-card-price" style="color: #fff;">£24.99</span>
      </div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
