<style>
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .bento-bottom-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    flex: 1;
  }
  .bento-hover-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .bento-hover-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.08);
  }
  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
    .bento-bottom-split {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="app-container" style="padding-top: 80px; padding-bottom: 80px;">
  <div style="text-align: center; max-width: 600px; margin: 0 auto 64px;">
    <h2 style="font-family: 'Outfit', serif; font-size: 48px; font-weight: normal; color: #131110; margin: 0 0 16px; letter-spacing: -1px;">
      {{ section.settings.title }}
    </h2>
    <p style="font-size: 14px; color: #666; line-height: 1.6;">
      Our collection of modern, timeless, and smart pet gear is designed to add warmth, comfort, and beauty to your home.
    </p>
  </div>

  {% assign target_collection = collections[section.settings.collection] %}
  {% if target_collection.products.size >= 3 %}
    <div class="bento-grid">
      
      <!-- Left: Large Card (Product 1) -->
      {% assign product_1 = target_collection.products[0] %}
      <div class="bento-hover-card" style="background: #fff; border-radius: 24px; padding: 48px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
        <a href="{{ product_1.url }}" style="text-decoration: none; color: inherit; display: block; width: 100%;">
          <div style="height: 320px; display: flex; align-items: center; justify-content: center; margin-bottom: 32px;">
            <img src="{{ product_1.featured_image | img_url: '800x' }}" alt="{{ product_1.title | escape }}" style="max-height: 100%; max-width: 100%; object-fit: contain;" />
          </div>
          <h3 style="font-family: 'Outfit', serif; font-size: 24px; font-weight: normal; margin-bottom: 16px; color: #131110;">{{ product_1.title }}</h3>
          <p style="font-size: 13px; color: #888; line-height: 1.6; margin-bottom: 32px; max-width: 80%; margin-left: auto; margin-right: auto;">
            {{ product_1.description | strip_html | truncatewords: 15 }}
          </p>
          <button style="background: #131110; color: #fff; border: none; padding: 14px 32px; border-radius: 50px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 8px;">
            Add to Cart
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </a>
      </div>

      <!-- Right Column -->
      <div style="display: flex; flex-direction: column; gap: 24px;">
        
        <!-- Right Top: Wide Dark Card (Product 2) -->
        {% assign product_2 = target_collection.products[1] %}
        <div class="bento-hover-card" style="background: #282828; border-radius: 24px; padding: 40px; color: #fff; display: flex; align-items: center; gap: 24px; flex: 1;">
          <div style="flex: 1;">
            <a href="{{ product_2.url }}" style="text-decoration: none; color: inherit;">
              <h3 style="font-family: 'Outfit', serif; font-size: 20px; font-weight: normal; margin-bottom: 16px;">{{ product_2.title }}</h3>
              <p style="font-size: 12px; color: #aaa; line-height: 1.6; margin-bottom: 24px;">
                {{ product_2.description | strip_html | truncatewords: 15 }}
              </p>
              <span style="font-size: 12px; font-weight: 700; display: inline-flex; align-items: center; gap: 6px; border-bottom: 1px solid #fff; padding-bottom: 2px;">
                Add to Cart <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>
          <div style="width: 160px; height: 180px; background: rgba(0,0,0,0.2); border-radius: 16px; display: flex; align-items: center; justify-content: center; padding: 16px;">
            <img src="{{ product_2.featured_image | img_url: '400x' }}" alt="{{ product_2.title | escape }}" style="max-height: 100%; max-width: 100%; object-fit: contain;" />
          </div>
        </div>

        <!-- Right Bottom: Split Cards -->
        <div class="bento-bottom-split">
          
          <!-- Product 3 -->
          {% assign product_3 = target_collection.products[2] %}
          <div class="bento-hover-card" style="background: #fff; border-radius: 24px; padding: 32px; text-align: center; display: flex; flex-direction: column; justify-content: space-between;">
            <a href="{{ product_3.url }}" style="text-decoration: none; color: inherit;">
              <div style="height: 140px; display: flex; align-items: center; justify-content: center; margin-bottom: 24px;">
                <img src="{{ product_3.featured_image | img_url: '400x' }}" alt="{{ product_3.title | escape }}" style="max-height: 100%; max-width: 100%; object-fit: contain;" />
              </div>
              <h3 style="font-family: 'Outfit', serif; font-size: 16px; font-weight: normal; margin-bottom: 12px; color: #131110;">{{ product_3.title }}</h3>
              <p style="font-size: 11px; color: #888; margin-bottom: 24px; line-height: 1.5;">
                {{ product_3.description | strip_html | truncatewords: 10 }}
              </p>
              <span style="font-size: 11px; font-weight: 700; color: #131110; display: inline-flex; align-items: center; gap: 4px;">
                Add to Cart <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>

          <!-- See Collection Card -->
          <div class="bento-hover-card" style="background: #0c0a09; border-radius: 24px; padding: 24px; display: flex; align-items: center; justify-content: center;">
            <a href="{{ target_collection.url }}" style="border: 1px solid rgba(255,255,255,0.15); padding: 14px 28px; border-radius: 50px; font-size: 11px; font-weight: 700; color: #fff; text-decoration: none; display: inline-flex; align-items: center; gap: 12px; transition: background 0.3s ease;">
              SEE COLLECTION
              <span style="background: #fff; color: #0c0a09; width: 24px; height: 24px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>

        </div>
      </div>
    </div>
  {% else %}
    <p style="text-align: center;">Please assign a collection with at least 3 products.</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
