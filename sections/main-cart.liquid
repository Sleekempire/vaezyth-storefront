<style>
  .cp-wrapper {
    background-color: #faf8f4;
    min-height: 100vh;
    padding: 60px 5% 100px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #1a201c;
  }
  .cp-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .cp-title-wrap {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }
  .cp-title {
    font-family: 'Outfit', sans-serif;
    font-size: 36px;
    font-weight: 700;
    color: #1c1917;
    margin: 0;
  }
  .cp-count-badge {
    background: #4A5D4E;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 50px;
  }
  
  /* Grid Layout */
  .cp-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 40px;
    align-items: start;
  }

  /* Left Column: Items */
  .cp-items-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .cp-card {
    background: #fff;
    border-radius: 20px;
    padding: 24px;
    display: flex;
    gap: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    border: 1px solid #f0ece6;
    position: relative;
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .cp-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.04);
  }
  .cp-card-img {
    width: 100px;
    height: 100px;
    border-radius: 14px;
    object-fit: cover;
    background: #faf8f4;
    border: 1px solid #f5f1ec;
    flex-shrink: 0;
  }
  .cp-card-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .cp-card-meta h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #1c1917;
    margin: 0 0 6px;
    line-height: 1.3;
  }
  .cp-card-meta h3 a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }
  .cp-card-meta h3 a:hover {
    color: #4A5D4E;
  }
  .cp-card-variant {
    font-size: 13px;
    color: #8c867e;
    margin: 0 0 12px;
  }
  .cp-card-remove {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #b0aba4;
    text-decoration: none;
    font-size: 12px;
    font-weight: 600;
    transition: color 0.2s;
  }
  .cp-card-remove:hover {
    color: #c0392b;
  }

  /* Right column elements aligned on card */
  .cp-card-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    flex-shrink: 0;
  }
  .cp-card-price-each {
    font-size: 13px;
    color: #888;
    margin-bottom: 4px;
  }
  .cp-card-price-total {
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #8C7A5D;
  }
  
  /* Qty Box */
  .cp-qty-box {
    display: flex;
    align-items: center;
    background: #f5f1ec;
    border-radius: 30px;
    padding: 3px;
  }
  .cp-qty-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    color: #666;
    text-decoration: none;
    font-size: 14px;
    font-weight: bold;
    transition: background 0.15s, color 0.15s;
  }
  .cp-qty-btn:hover {
    background: #fff;
    color: #1c1917;
  }
  .cp-qty-val {
    width: 32px;
    text-align: center;
    font-size: 13px;
    font-weight: 700;
    color: #1c1917;
    border: none;
    background: transparent;
  }

  /* Right Column: Summary Card */
  .cp-summary-card {
    background: #fff;
    border-radius: 24px;
    padding: 28px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    border: 1px solid #f0ece6;
  }
  .cp-summary-title {
    font-family: 'Outfit', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #1c1917;
    margin: 0 0 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid #f0ece6;
  }
  
  /* Shipping Progress */
  .cp-progress-wrap {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid #f0ece6;
  }
  .cp-progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  .cp-progress-label {
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: #999;
  }
  .cp-progress-status {
    font-size: 12px;
    font-weight: 700;
    color: #4A5D4E;
  }
  .cp-progress-bar-track {
    height: 6px;
    background: #eae6df;
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .cp-progress-bar-fill {
    height: 100%;
    background: #4A5D4E;
    border-radius: 3px;
  }
  .cp-progress-msg {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: #555;
    font-weight: 500;
  }
  .cp-progress-msg svg {
    color: #4A5D4E;
  }

  /* Summary details list */
  .cp-summary-rows {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }
  .cp-summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    color: #555;
    font-weight: 500;
  }
  .cp-summary-row.total {
    border-top: 1px solid #f0ece6;
    padding-top: 16px;
    margin-top: 8px;
    font-size: 16px;
    color: #1c1917;
    font-weight: 700;
  }
  .cp-total-large {
    font-family: 'Outfit', sans-serif;
    font-size: 24px;
    font-weight: 800;
    color: #4A5D4E;
  }

  .cp-checkout-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #4A5D4E;
    color: #fff;
    padding: 16px;
    border: none;
    border-radius: 50px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }
  .cp-checkout-btn:hover {
    background: #3d4e41;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(74, 93, 78, 0.15);
  }
  .cp-checkout-btn:active {
    transform: translateY(0);
  }

  .cp-trust-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 16px;
    color: #8c867e;
    font-size: 11px;
    font-weight: 500;
  }

  /* Empty state styles */
  .cp-empty {
    text-align: center;
    background: #fff;
    border-radius: 24px;
    padding: 80px 40px;
    border: 1px solid #f0ece6;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  }
  .cp-empty-icon {
    width: 72px;
    height: 72px;
    background: #f6f5f0;
    color: #4A5D4E;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }
  .cp-empty-title {
    font-family: 'Outfit', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: #1c1917;
    margin: 0 0 8px;
  }
  .cp-empty-text {
    font-size: 14px;
    color: #666;
    margin: 0 0 32px;
  }
  .cp-empty-btn {
    display: inline-flex;
    background: #4A5D4E;
    color: #fff;
    padding: 14px 36px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .cp-empty-btn:hover {
    opacity: 0.85;
  }

  /* Responsive Design */
  @media (max-width: 950px) {
    .cp-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
  @media (max-width: 600px) {
    .cp-wrapper {
      padding: 40px 4% 60px;
    }
    .cp-title {
      font-size: 28px;
    }
    .cp-card {
      flex-direction: column;
      gap: 16px;
      padding: 16px;
    }
    .cp-card-img {
      width: 100%;
      height: 160px;
    }
    .cp-card-actions {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid #f5f1ec;
      padding-top: 14px;
      margin-top: 8px;
    }
    .cp-card-price-total {
      font-size: 18px;
    }
  }
</style>

<div class="cp-wrapper">
  <div class="cp-container">

    {% if cart.item_count == 0 %}
      <!-- Empty State -->
      <div class="cp-empty">
        <div class="cp-empty-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        </div>
        <h2 class="cp-empty-title">Your Basket is Empty</h2>
        <p class="cp-empty-text">Fill it with high-quality pet essentials built to last.</p>
        <a href="/collections/all" class="cp-empty-btn">Explore Products</a>
      </div>
    {% else %}
      
      <div class="cp-title-wrap">
        <h1 class="cp-title">Your Basket</h1>
        <span class="cp-count-badge">{{ cart.item_count }}</span>
      </div>

      <div class="cp-grid">
        <!-- Left: Items list -->
        <div class="cp-items-list">
          {% for item in cart.items %}
            <div class="cp-card">
              {% if item.image %}
                <img src="{{ item.image | img_url: '200x' }}" alt="{{ item.title | escape }}" class="cp-card-img" loading="lazy" />
              {% endif %}
              
              <div class="cp-card-details">
                <div class="cp-card-meta">
                  <h3><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
                  {% unless item.variant.title == 'Default Title' %}
                    <p class="cp-card-variant">{{ item.variant.title | replace: ' / ', ' • ' }}</p>
                  {% endunless %}
                  <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="cp-card-remove">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                    Remove Item
                  </a>
                </div>
              </div>

              <div class="cp-card-actions">
                <div>
                  <div class="cp-card-price-each">{{ item.price | money }} each</div>
                  <span class="cp-card-price-total">{{ item.line_price | money }}</span>
                </div>
                
                <div class="cp-qty-box">
                  <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" class="cp-qty-btn">−</a >
                  <input type="text" value="{{ item.quantity }}" class="cp-qty-val" readonly />
                  <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" class="cp-qty-btn">+</a>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <!-- Right: Summary Sidebar -->
        <div class="cp-summary-card">
          <h2 class="cp-summary-title">Order Summary</h2>

          <!-- Shipping Progress -->
          {% assign threshold = 3000 %}
          <div class="cp-progress-wrap">
            <div class="cp-progress-header">
              <span class="cp-progress-label">Free Shipping Progress</span>
              <span class="cp-progress-status">
                {% if cart.total_price < threshold %}
                  {% assign remaining = threshold | minus: cart.total_price %}
                  {{ remaining | money }} away
                {% else %}
                  Unlocked!
                {% endif %}
              </span>
            </div>
            <div class="cp-progress-bar-track">
              {% if cart.total_price < threshold %}
                {% assign pct = cart.total_price | times: 100 | divided_by: threshold %}
              {% else %}
                {% assign pct = 100 %}
              {% endif %}
              <div class="cp-progress-bar-fill" style="width: {{ pct }}%;"></div>
            </div>
            <div class="cp-progress-msg">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="1" y="3" width="15" height="13" rx="2" ry="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>
                {% if cart.total_price < threshold %}
                  Add {{ remaining | money }} more to unlock free delivery!
                {% else %}
                  You have unlocked free delivery!
                {% endif %}
              </span>
            </div>
          </div>

          <!-- Price summary rows -->
          <div class="cp-summary-rows">
            <div class="cp-summary-row">
              <span>Subtotal</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <div class="cp-summary-row">
              <span>Delivery</span>
              <span>
                {% if cart.total_price >= threshold %}
                  FREE
                {% else %}
                  £2.99
                {% endif %}
              </span>
            </div>
            
            {% if cart.total_price >= threshold %}
              {% assign total_val = cart.total_price %}
            {% else %}
              {% assign total_val = cart.total_price | plus: 299 %}
            {% endif %}
            
            <div class="cp-summary-row total">
              <span>Total Amount</span>
              <span class="cp-total-large">{{ total_val | money }}</span>
            </div>
          </div>

          <form action="/cart" method="post" novalidate style="margin: 0;">
            <button type="submit" name="checkout" class="cp-checkout-btn">
              <span>Proceed to Checkout</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </form>

          <div class="cp-trust-badge">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span>Secure Checkout Powered by Shopify</span>
          </div>
        </div>
      </div>

    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
