<style>
  .luxury-cart-page {
    background-color: #f3f2ee;
    min-height: 100vh;
    padding: 60px 8% 80px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #2b2b2b;
  }
  .luxury-cart-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  /* Grid Layout */
  .luxury-cart-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 48px;
    align-items: start;
  }

  /* Left Column: Curated Info & Upsell */
  .luxury-cart-info-col {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .luxury-cart-tagline {
    font-family: 'Outfit', sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #8c867e;
    display: block;
    margin-bottom: 12px;
  }
  .luxury-cart-desc {
    font-size: 13px;
    line-height: 1.6;
    color: #6e675f;
    margin: 0;
  }

  /* Upsell Card */
  .luxury-upsell-card {
    background: #fbfaf8;
    border-radius: 12px;
    padding: 20px;
    border: 1px solid #e6e3dd;
  }
  .luxury-upsell-title {
    font-family: 'Outfit', sans-serif;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: #73706c;
    margin: 0 0 16px;
  }
  .luxury-upsell-item {
    background: #fff;
    border: 1px solid #e6e3dd;
    border-radius: 8px;
    padding: 12px;
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .luxury-upsell-img {
    width: 48px;
    height: 48px;
    border-radius: 4px;
    object-fit: cover;
    background: #faf8f4;
    border: 1px solid #e6e3dd;
  }
  .luxury-upsell-details h4 {
    font-family: 'Outfit', sans-serif;
    font-size: 12.5px;
    font-weight: 700;
    color: #555;
    margin: 0 0 2px;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .luxury-upsell-price {
    font-size: 11px;
    color: #888;
    display: block;
    margin-bottom: 6px;
  }
  .luxury-upsell-add-btn {
    background: none;
    border: none;
    padding: 0;
    color: #4A5D4E;
    font-size: 10px;
    font-weight: 700;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1.5px solid #4A5D4E;
    padding-bottom: 1px;
  }

  /* Right Column: Items */
  .luxury-cart-items-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .luxury-item-card {
    background: #fff;
    border-radius: 12px;
    padding: 24px;
    display: flex;
    gap: 24px;
    border: 1px solid #e6e3dd;
    position: relative;
  }
  .luxury-item-img-wrap {
    width: 120px;
    height: 120px;
    border-radius: 8px;
    overflow: hidden;
    background: #faf8f4;
    border: 1px solid #e6e3dd;
    flex-shrink: 0;
  }
  .luxury-item-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .luxury-item-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .luxury-item-title {
    font-family: 'Outfit', sans-serif;
    font-size: 22px;
    font-weight: 400;
    color: #4A5D4E;
    margin: 0 0 4px;
    line-height: 1.25;
    text-decoration: none;
  }
  .luxury-item-title:hover {
    color: #3d4e41;
  }
  .luxury-item-variant {
    font-size: 12px;
    color: #8c867e;
    margin: 0;
  }
  
  /* Minimalist Quantity Selector */
  .luxury-qty-selector {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    margin-top: auto;
  }
  .luxury-qty-btn {
    color: #999;
    text-decoration: none;
    font-size: 16px;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .luxury-qty-btn:hover {
    color: #1c1917;
  }
  .luxury-qty-val {
    font-size: 13px;
    font-weight: 600;
    color: #1c1917;
  }

  .luxury-item-remove {
    position: absolute;
    top: 24px;
    right: 24px;
    color: #b3b0aa;
    text-decoration: none;
    font-size: 16px;
    line-height: 1;
    transition: color 0.2s;
  }
  .luxury-item-remove:hover {
    color: #c0392b;
  }
  .luxury-item-price {
    position: absolute;
    bottom: 24px;
    right: 24px;
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 400;
    color: #555;
  }

  /* Bottom Summary Bar - Full Width Stretch */
  .luxury-bottom-bar {
    position: relative;
    margin-top: 60px;
    background: #fbfaf8;
    border-top: 1px solid #e6e3dd;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    border-radius: 40px 40px 0 0;
    padding: 32px 10%;
  }
  .luxury-bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .luxury-bottom-left {
    display: flex;
    align-items: center;
    gap: 48px;
  }
  .luxury-subtotal-wrap {
    display: flex;
    flex-direction: column;
  }
  .luxury-subtotal-label {
    font-size: 10px;
    font-weight: 800;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 2px;
  }
  .luxury-subtotal-val {
    font-family: 'Outfit', sans-serif;
    font-size: 28px;
    font-weight: 400;
    color: #1c1917;
    line-height: 1;
  }
  .luxury-shipping-info {
    display: flex;
    flex-direction: column;
  }
  .luxury-shipping-label {
    font-size: 10px;
    font-weight: 800;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 2px;
  }
  .luxury-shipping-val {
    font-size: 13px;
    color: #666;
  }
  .luxury-checkout-btn {
    background: #4A5D4E;
    color: #fff;
    border: none;
    padding: 14px 40px;
    border-radius: 50px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .luxury-checkout-btn:hover {
    background: #3d4e41;
  }

  /* Empty State */
  .luxury-empty {
    text-align: center;
    background: #fff;
    border-radius: 12px;
    padding: 100px 40px;
    border: 1px solid #e6e3dd;
    box-shadow: 0 4px 20px rgba(0,0,0,0.01);
  }
  .luxury-empty-icon {
    width: 80px;
    height: 80px;
    background: #faf8f4;
    color: #4A5D4E;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    border: 1px solid #e6e3dd;
  }
  .luxury-empty-title {
    font-family: 'Outfit', sans-serif;
    font-size: 26px;
    font-weight: 700;
    color: #1c1917;
    margin: 0 0 8px;
  }
  .luxury-empty-text {
    font-size: 15px;
    color: #666;
    margin: 0 0 32px;
  }
  .luxury-empty-btn {
    display: inline-flex;
    background: #4A5D4E;
    color: #fff;
    padding: 14px 40px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .luxury-empty-btn:hover {
    opacity: 0.85;
  }

  /* Responsive styling */
  @media (max-width: 950px) {
    .luxury-cart-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
  @media (max-width: 768px) {
    .luxury-bottom-bar {
      padding: 20px 5%;
    }
    .luxury-bottom-inner {
      flex-direction: column;
      gap: 16px;
      align-items: stretch;
      text-align: center;
    }
    .luxury-bottom-left {
      justify-content: space-around;
      gap: 20px;
    }
    .luxury-checkout-btn {
      justify-content: center;
    }
    .luxury-cart-page {
      padding-bottom: 220px;
    }
  }
  @media (max-width: 600px) {
    .luxury-item-card {
      flex-direction: column;
      gap: 16px;
      padding: 16px;
    }
    .luxury-item-img-wrap {
      width: 100%;
      height: 160px;
    }
    .luxury-item-price {
      position: static;
      margin-top: 12px;
      text-align: right;
      display: block;
    }
    .luxury-item-remove {
      top: 16px;
      right: 16px;
    }
  }
</style>

<div class="luxury-cart-page">
  <div class="luxury-cart-container">

    {% if cart.item_count == 0 %}
      <!-- Empty state -->
      <div class="luxury-empty">
        <div class="luxury-empty-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        </div>
        <h2 class="luxury-empty-title">Your Basket is Empty</h2>
        <p class="luxury-empty-text">Fill it with high-quality pet essentials built to last.</p>
        <a href="/collections/all" class="luxury-empty-btn">Explore Products</a>
      </div>
    {% else %}

      <div class="luxury-cart-grid">
        
        <!-- Left column: Info & Upsell -->
        <div class="luxury-cart-info-col">
          <div>
            <span class="luxury-cart-tagline">Your Curated Selection</span>
            <p class="luxury-cart-desc">Hand-picked essentials for the modern pet. Every piece is a testament to architectural grace and nurturing comfort.</p>
          </div>

          <!-- Upsell Block -->
          {% assign recommend_product = collections['all'].products | first %}
          {% if recommend_product %}
            <div class="luxury-upsell-card">
              <h3 class="luxury-upsell-title">Complete the Look</h3>
              <div class="luxury-upsell-item">
                <img src="{{ recommend_product.featured_image | img_url: '120x' }}" alt="{{ recommend_product.title | escape }}" class="luxury-upsell-img" />
                <div class="luxury-upsell-details">
                  <h4>{{ recommend_product.title }}</h4>
                  <span class="luxury-upsell-price">{{ recommend_product.price | money }}</span>
                  <form action="/cart/add" method="post" style="margin: 0;">
                    <input type="hidden" name="id" value="{{ recommend_product.variants.first.id }}" />
                    <button type="submit" class="luxury-upsell-add-btn">
                      ADD TO BAG &rarr;
                    </button>
                  </form>
                </div>
              </div>
            </div>
          {% endif %}
        </div>

        <!-- Right column: Cart Items list -->
        <div class="luxury-cart-items-col">
          {% for item in cart.items %}
            <div class="luxury-item-card">
              <!-- Delete Button -->
              <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="luxury-item-remove" aria-label="Remove item">✕</a>
              
              <!-- Product Image -->
              <div class="luxury-item-img-wrap">
                <img src="{{ item.image | img_url: '300x' }}" alt="{{ item.title | escape }}" class="luxury-item-img" loading="lazy" />
              </div>

              <!-- Product Details -->
              <div class="luxury-item-details">
                <div>
                  <h3><a href="{{ item.url }}" class="luxury-item-title">{{ item.product.title }}</a></h3>
                  {% unless item.variant.title == 'Default Title' %}
                    <p class="luxury-item-variant">{{ item.variant.title | replace: ' / ', ' • ' }}</p>
                  {% endunless %}
                </div>

                <!-- Minimal quantity controls -->
                <div class="luxury-qty-selector">
                  <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" class="luxury-qty-btn">&minus;</a>
                  <span class="luxury-qty-val">{{ item.quantity }}</span>
                  <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" class="luxury-qty-btn">+</a>
                </div>
              </div>

              <!-- Price -->
              <span class="luxury-item-price">{{ item.line_price | money }}</span>
            </div>
          {% endfor %}
        </div>

      </div>

      <!-- Bottom Sticky Bar -->
      <div class="luxury-bottom-bar">
        <div class="luxury-bottom-inner">
          <div class="luxury-bottom-left">
            <div class="luxury-subtotal-wrap">
              <span class="luxury-subtotal-label">Subtotal</span>
              <span class="luxury-subtotal-val">{{ cart.total_price | money }}</span>
            </div>
            <div class="luxury-shipping-info">
              <span class="luxury-shipping-label">Shipping</span>
              <span class="luxury-shipping-val">Calculated at next step</span>
            </div>
          </div>

          <form action="/cart" method="post" novalidate style="margin: 0;">
            <button type="submit" name="checkout" class="luxury-checkout-btn">
              <span>Proceed to Checkout</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </form>
        </div>
      </div>

    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
