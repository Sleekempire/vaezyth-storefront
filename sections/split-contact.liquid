<div class="split-contact-section split-contact-container" style="background-color: #f6f5f0; font-family: 'Plus Jakarta Sans', sans-serif;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <h2 class="split-contact-title">
      {{ section.settings.title }}
    </h2>
    
    <div class="split-contact-grid">
      
      <!-- Left Column -->
      <div style="display: flex; flex-direction: column; align-items: center; text-align: center;">
        <div style="width: 280px; height: 280px; background-color: #111; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 32px; box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
          <div style="width: 140px; height: 140px; background: url('{{ 'dark_architectural_contact.jpg' | asset_url }}') center/cover; border-radius: 12px; border: 4px solid #333;" onerror="this.style.background='#fff'"></div>
        </div>
        <p style="font-size: 10px; color: #666; line-height: 1.6; max-width: 280px; text-transform: uppercase; letter-spacing: 0.5px;">
          {{ section.settings.left_text }}<br><br>
          <a href="mailto:support@vaezyth.com" style="color: #111; font-weight: 800; font-size: 13px; text-decoration: none; border-bottom: 2px solid #111; padding-bottom: 2px;">support@vaezyth.com</a>
        </p>
      </div>

      <!-- Right Column: Contact Form -->
      <div class="contact-form-wrapper" style="background: #fff; padding: 48px; border-radius: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <div style="background: #111; color: #fff; padding: 16px; border-radius: 50px; margin-bottom: 24px; text-align: center; font-size: 12px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px;">
              Thanks for reaching out! We'll get back to you soon.
            </div>
          {% endif %}

          {{ form.errors | default_errors }}

          <div class="contact-form-row">
            <div style="display: flex; flex-direction: column;">
              <input type="text" id="ContactFormName" name="contact[name]" placeholder="Name" style="padding: 16px 24px; border: 1px solid rgba(0,0,0,0.1); border-radius: 50px; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13px; outline: none; background: transparent; transition: border-color 0.3s ease;" onfocus="this.style.borderColor='#111'" onblur="this.style.borderColor='rgba(0,0,0,0.1)'">
            </div>
            <div style="display: flex; flex-direction: column;">
              <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="Email *" required style="padding: 16px 24px; border: 1px solid rgba(0,0,0,0.1); border-radius: 50px; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13px; outline: none; background: transparent; transition: border-color 0.3s ease;" onfocus="this.style.borderColor='#111'" onblur="this.style.borderColor='rgba(0,0,0,0.1)'">
            </div>
          </div>
          
          <div style="display: flex; flex-direction: column; margin-bottom: 32px;">
            <textarea rows="5" id="ContactFormMessage" name="contact[body]" placeholder="Message *" required style="padding: 24px; border: 1px solid rgba(0,0,0,0.1); border-radius: 24px; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13px; outline: none; background: transparent; resize: vertical; transition: border-color 0.3s ease;" onfocus="this.style.borderColor='#111'" onblur="this.style.borderColor='rgba(0,0,0,0.1)'"></textarea>
          </div>

          <button type="submit" style="width: 100%; background: #111; color: #fff; padding: 18px; border: none; border-radius: 50px; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.2)'" onmouseout="this.style.transform='none'; this.style.boxShadow='none'">
            Send Message
          </button>
        {% endform %}
      </div>

    </div>
  </div>
</div>

<style>
  .split-contact-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 80px; align-items: start; }
  .contact-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
  .split-contact-title { font-family: 'Outfit', serif; font-size: clamp(32px, 5vw, 48px); font-weight: 400; color: #111; text-align: center; margin-bottom: 80px; }
  .split-contact-container { padding: 100px 5%; }
  .contact-form-wrapper { background: #fff; padding: 48px; border-radius: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); }

  @media (max-width: 900px) {
    .split-contact-container { padding: 40px 5% !important; }
    .split-contact-grid {
      grid-template-columns: 1fr !important;
      gap: 48px !important;
    }
    .contact-form-row {
      grid-template-columns: 1fr !important;
      gap: 16px !important;
    }
    .split-contact-title { font-size: 32px !important; margin-bottom: 40px !important; }
    .contact-form-wrapper { padding: 24px !important; }
  }
</style>

{% schema %}
{
  "name": "Split Contact",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "textarea",
      "id": "left_text",
      "label": "Left Column Text",
      "default": "We value clear communication and transparency. Drop us a line and our team will get back to you."
    }
  ],
  "presets": [
    {
      "name": "Split Contact"
    }
  ]
}
{% endschema %}
