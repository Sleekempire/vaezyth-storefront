<div class="template-hero">
  <div class="hero-left-panel">
    <h1>{{ section.settings.heading }}</h1>
    <a href="{{ section.settings.button_link }}" class="btn-hero-cta" style="background: #222; color: #fff; border-radius: 50px; border: 1px solid #444; padding: 10px 24px; letter-spacing: 1px; text-transform: uppercase; font-size: 11px; font-weight: bold; text-decoration: none; display: inline-block;">
      {{ section.settings.button_text }} ↗
    </a>
    <div style="display: flex; gap: 8px; margin-top: auto;">
      <span style="border: 1px solid rgba(255,255,255,0.2); padding: 6px 14px; border-radius: 50px; font-size: 10px; color: #fff;">Premium Grade *</span>
      <span style="border: 1px solid rgba(255,255,255,0.2); padding: 6px 14px; border-radius: 50px; font-size: 10px; color: #fff;">Ergonomic *</span>
      <span style="border: 1px solid rgba(255,255,255,0.2); padding: 6px 14px; border-radius: 50px; font-size: 10px; color: #fff;">Auto-Brake *</span>
      <span style="border: 1px solid rgba(255,255,255,0.2); padding: 6px 14px; border-radius: 50px; font-size: 10px; color: #fff;">360 Swivel *</span>
    </div>
  </div>
  <div style="display: flex; flex-direction: column; align-items: flex-end; height: 100%;">
    <p style="color: #fff; font-size: 14px; max-width: 300px; text-align: right; margin-bottom: 40px; line-height: 1.6;">
      {{ section.settings.description }}
    </p>
    <div class="hero-right-media" style="position: relative; border-radius: 16px; overflow: hidden; width: 100%; height: 300px;">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading }}" style="width: 100%; height: 100%; object-fit: cover;" />
      {% else %}
        <img src="{{ 'leash_luxury_hero.jpg' | asset_url }}" alt="Leash" style="width: 100%; height: 100%; object-fit: cover;" />
      {% endif %}
      <div style="position: absolute; bottom: 20px; right: 20px; background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); padding: 16px; border-radius: 12px; color: #fff; border: 1px solid rgba(255,255,255,0.2);">
        <div style="font-size: 9px; font-weight: bold; letter-spacing: 1px; margin-bottom: 4px;">{{ section.settings.badge_sub }}</div>
        <div style="font-size: 14px; font-weight: bold; margin-bottom: 8px;">{{ section.settings.badge_title }}</div>
        <div style="font-size: 16px; font-weight: bold;">{{ section.settings.badge_price }}</div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Vaezyth"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover elegant, modern, and highly durable pet gear crafted to elevate every walk and complement your home."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "badge_sub",
      "label": "Badge Subtitle",
      "default": "5.0M NYLON TAPE"
    },
    {
      "type": "text",
      "id": "badge_title",
      "label": "Badge Title",
      "default": "Integrated Dispenser & LED"
    },
    {
      "type": "text",
      "id": "badge_price",
      "label": "Badge Price",
      "default": "£24.99"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
