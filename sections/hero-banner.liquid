<style>
  /* ── Hero Banner ── */
  .hero-wrap {
    background: #4A5D4E; /* Vaezyth Signature Dark Green */
    width: 100%;
    box-sizing: border-box;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* ── Embedded Header ── */
  .hero-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 48px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .hero-logo {
    font-family: 'Outfit', sans-serif;
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -1px;
    color: #ffffff;
    text-decoration: none;
  }
  .hero-nav {
    display: flex;
    gap: 36px;
    align-items: center;
  }
  .hero-nav a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: color 0.2s;
  }
  .hero-nav a:hover { color: #fff; }
  .hero-icons {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .hero-icon-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.8);
    cursor: pointer;
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
    text-decoration: none;
    position: relative;
  }
  .hero-icon-btn:hover { color: #fff; }
  .hero-cart-badge {
    position: absolute;
    top: 2px;
    right: 2px;
    background: #C5A880;
    color: #fff;
    border-radius: 50%;
    font-size: 9px;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
  }

  /* Mobile hamburger */
  .hero-hamburger {
    display: none;
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 8px;
  }
  .hero-mobile-menu {
    display: none;
    flex-direction: column;
    gap: 0;
    background: #111;
    padding: 0;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease;
  }
  .hero-mobile-menu.open { max-height: 300px; }
  .hero-mobile-menu a {
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    padding: 16px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: background 0.2s, color 0.2s;
  }
  .hero-mobile-menu a:hover { background: rgba(255,255,255,0.05); color: #fff; }

  /* ── Hero Content ── */
  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    padding: 40px 48px 56px;
    align-items: center;
  }

  .hero-left { display: flex; flex-direction: column; align-items: flex-start; gap: 20px; }

  .hero-cta-pill {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 50px;
    padding: 6px 6px 6px 22px;
    color: #fff;
    text-decoration: none;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: background 0.3s;
  }
  .hero-cta-pill:hover { background: rgba(255,255,255,0.14); }
  .hero-cta-pill span {
    background: #fff;
    color: #111;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
  }

  .hero-pills-row { display: flex; gap: 8px; flex-wrap: wrap; }
  .hero-pill {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 11px;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
    backdrop-filter: blur(8px);
  }

  .hero-right { display: flex; flex-direction: column; align-items: flex-end; gap: 20px; }
  .hero-desc {
    color: rgba(255,255,255,0.7);
    font-size: 15px;
    max-width: 300px;
    text-align: right;
    line-height: 1.65;
  }

  .hero-media-wrap {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    width: 100%;
    max-height: 340px;
  }
  .hero-media-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    max-height: 340px;
  }
  .hero-badge {
    position: absolute;
    bottom: 18px;
    right: 18px;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 14px;
    padding: 14px 18px;
    color: #fff;
  }
  .hero-badge-sub { font-size: 9px; font-weight: 700; letter-spacing: 1.5px; opacity: 0.7; margin-bottom: 4px; text-transform: uppercase; }
  .hero-badge-title { font-size: 13px; font-weight: 700; margin-bottom: 4px; }
  .hero-badge-price { font-size: 18px; font-weight: 800; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-header { padding: 16px 20px; }
    .hero-nav { display: none; }
    .hero-hamburger { display: flex; }
    .hero-mobile-menu { display: flex; }
    .hero-content {
      grid-template-columns: 1fr;
      padding: 24px 20px 32px;
      gap: 24px;
    }
    .hero-left { align-items: center; }
    .hero-pills-row { justify-content: center; }
    .hero-right { align-items: center; }
    .hero-desc { text-align: center; max-width: 100%; font-size: 13px; }
    .hero-media-wrap { max-height: 220px; }
    .hero-badge { padding: 10px 14px; }
    .hero-badge-title { font-size: 11px; }
    .hero-badge-price { font-size: 15px; }
  }
  @media (max-width: 480px) {
    .hero-logo { font-size: 22px; }
    .hero-pills-row { gap: 6px; }
    .hero-pill { font-size: 10px; padding: 6px 12px; }
    .hero-media-wrap { max-height: 180px; }
  }
</style>

<div class="hero-wrap">

  <!-- ── Embedded Header/Nav ── -->
  <div class="hero-header">
    <!-- Logo -->
    <a href="/" class="hero-logo">VAEZYTH</a>

    <!-- Desktop Nav -->
    <nav class="hero-nav">
      <a href="/">Home</a>
      <a href="/collections/all">Catalog</a>
      <a href="/pages/contact">Contact</a>
    </nav>

    <!-- Icons -->
    <div class="hero-icons">
      <a href="/account" class="hero-icon-btn" title="Account">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <button class="hero-icon-btn cart-toggle-btn" title="Cart" style="position:relative;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        <span class="hero-cart-badge badge-cart-count" id="cart-item-count">0</span>
      </button>
      <!-- Hamburger (mobile) -->
      <button class="hero-hamburger" onclick="document.getElementById('HeroMobileMenu').classList.toggle('open')" title="Menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu dropdown -->
  <div class="hero-mobile-menu" id="HeroMobileMenu">
    <a href="/">Home</a>
    <a href="/collections/all">Catalog</a>
    <a href="/pages/contact">Contact</a>
  </div>

  <!-- ── Hero Content ── -->
  <div class="hero-content">

    <!-- Left -->
    <div class="hero-left">
      <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="hero-cta-pill">
        {{ section.settings.button_text | default: 'Shop Collection' }}
        <span>↗</span>
      </a>
      <div class="hero-pills-row">
        <span class="hero-pill">Durable Materials</span>
        <span class="hero-pill">Modern Aesthetics</span>
        <span class="hero-pill">Everyday Comfort</span>
        <span class="hero-pill">Built to Last</span>
      </div>
    </div>

    <!-- Right -->
    <div class="hero-right">
      <p class="hero-desc">{{ section.settings.description | default: 'Smart pet products. Built to last.' }}</p>
      <div class="hero-media-wrap">
        {% if section.settings.image != blank %}
          <img class="hero-media-img" src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading }}">
        {% else %}
          <img class="hero-media-img" src="{{ 'leash_luxury_hero.jpg' | asset_url }}" alt="Vaezyth Hero">
        {% endif %}
        <div class="hero-badge">
          <div class="hero-badge-sub">{{ section.settings.badge_sub | default: '5.0M NYLON TAPE' }}</div>
          <div class="hero-badge-title">{{ section.settings.badge_title | default: 'Integrated Dispenser & LED' }}</div>
          <div class="hero-badge-price">{{ section.settings.badge_price | default: '£24.99' }}</div>
        </div>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Vaezyth" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Smart pet products. Built to last." },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "Shop Collection" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "image_picker", "id": "image", "label": "Hero Image" },
    { "type": "text", "id": "badge_sub", "label": "Badge Subtitle", "default": "5.0M NYLON TAPE" },
    { "type": "text", "id": "badge_title", "label": "Badge Title", "default": "Integrated Dispenser & LED" },
    { "type": "text", "id": "badge_price", "label": "Badge Price", "default": "£24.99" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
