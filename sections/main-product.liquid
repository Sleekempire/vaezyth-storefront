{% comment %} Vaezyth – Main Product Section {% endcomment %}

<style>
  /* ════════════════════════════
     BASE
  ════════════════════════════ */
  .vp-wrap {
    background: #faf8f4;
    padding: 0 0 20px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #1a201c;
  }

  /* ════════════════════════════
     STICKY MOBILE TOP BAR
  ════════════════════════════ */
  .vp-mobile-topbar {
    display: none;
    position: sticky;
    top: 0;
    z-index: 200;
    background: #faf8f4;
    border-bottom: 1px solid #e8e3da;
    padding: 12px 20px;
    align-items: center;
    gap: 12px;
  }
  .vp-mobile-back {
    display: flex;
    align-items: center;
    color: #4A5D4E;
    text-decoration: none;
    font-size: 13px;
    font-weight: 700;
    gap: 4px;
  }
  .vp-mobile-title {
    font-size: 14px;
    font-weight: 700;
    color: #1a201c;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .vp-mobile-price {
    font-size: 14px;
    font-weight: 700;
    color: #3b4d40;
    flex-shrink: 0;
  }

  /* ════════════════════════════
     PAGE CONTAINER
  ════════════════════════════ */
  .vp-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ════════════════════════════
     BREADCRUMB (desktop)
  ════════════════════════════ */
  .vp-crumb {
    font-size: 11px;
    color: #aaa;
    padding: 24px 0 28px;
    letter-spacing: 0.2px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .vp-crumb a {
    color: #aaa;
    text-decoration: none;
    transition: color 0.2s;
  }
  .vp-crumb a:hover { color: #4A5D4E; }
  .vp-crumb-sep { color: #ccc; }
  .vp-crumb-current { color: #555; font-weight: 600; }

  /* ════════════════════════════
     TWO-COLUMN LAYOUT
  ════════════════════════════ */
  .vp-cols {
    display: grid;
    grid-template-columns: 56% 44%;
    gap: 56px;
    align-items: start;
  }

  /* ════════════════════════════
     GALLERY
  ════════════════════════════ */
  .vp-gallery { display: flex; flex-direction: column; gap: 14px; }

  .vp-main-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 18px;
    overflow: hidden;
    background: #ede9e2;
    position: relative;
  }
  #VpMainImg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .vp-main-wrap:hover #VpMainImg { transform: scale(1.03); }

  /* Mobile swipe indicator */
  .vp-swipe-hint {
    display: none;
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.45);
    color: #fff;
    font-size: 10px;
    padding: 4px 10px;
    border-radius: 20px;
    letter-spacing: 0.3px;
    pointer-events: none;
  }

  .vp-thumbs-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  .vp-thumb {
    aspect-ratio: 1;
    border-radius: 10px;
    object-fit: cover;
    cursor: pointer;
    border: 2.5px solid transparent;
    background: #ede9e2;
    transition: border-color 0.2s, transform 0.15s;
    width: 100%;
    display: block;
  }
  .vp-thumb:hover { transform: scale(1.03); }
  .vp-thumb.active { border-color: #d97706; }

  /* ════════════════════════════
     PRODUCT INFO
  ════════════════════════════ */
  .vp-info-col { padding-top: 4px; }

  .vp-prod-title {
    font-family: 'Outfit', sans-serif;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    color: #1a201c;
    margin: 0 0 16px;
  }

  /* Stars + Price */
  .vp-rating-price {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .vp-stars { color: #f59e0b; font-size: 15px; letter-spacing: 2px; }
  .vp-review-count { font-size: 13px; color: #888; }
  .vp-price-tag {
    font-family: 'Outfit', sans-serif;
    font-size: 26px;
    font-weight: 700;
    color: #1a201c;
    margin-left: auto;
  }
  .vp-compare-tag {
    font-size: 14px;
    color: #bbb;
    text-decoration: line-through;
    margin-left: 6px;
  }

  .vp-divider { height: 1px; background: #e8e3da; margin: 20px 0; }

  /* Short desc */
  .vp-short-desc {
    font-size: 14px;
    line-height: 1.7;
    color: #666;
    margin-bottom: 24px;
  }

  /* ════════════════════════════
     OPTIONS
  ════════════════════════════ */
  .vp-opt-block { margin-bottom: 20px; }
  .vp-opt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .vp-opt-name {
    font-size: 13px;
    font-weight: 700;
    color: #1a201c;
  }
  .vp-opt-selected { font-weight: 400; color: #888; }
  .vp-size-guide {
    font-size: 11px;
    font-weight: 700;
    color: #4A5D4E;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-decoration: none;
  }
  .vp-size-guide:hover { text-decoration: underline; }
  .vp-opt-values { display: flex; flex-wrap: wrap; gap: 8px; }

  /* Size pills */
  .vp-size-pill {
    padding: 8px 18px;
    border: 1.5px solid #d5d0c8;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #444;
    background: #fff;
    cursor: pointer;
    transition: all 0.18s;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .vp-size-pill:hover { border-color: #4A5D4E; color: #4A5D4E; }
  .vp-size-pill.active {
    border-color: #1a201c;
    background: #1a201c;
    color: #fff;
  }

  /* Color swatches */
  .vp-color-swatch {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    cursor: pointer;
    border: 3px solid transparent;
    box-shadow: 0 0 0 1.5px #ccc;
    transition: box-shadow 0.18s, transform 0.15s;
    padding: 0;
  }
  .vp-color-swatch:hover { transform: scale(1.1); box-shadow: 0 0 0 2px #4A5D4E; }
  .vp-color-swatch.active {
    box-shadow: 0 0 0 2.5px #1a201c;
    border-color: #faf8f4;
  }

  /* ════════════════════════════
     QTY + ADD TO CART
  ════════════════════════════ */
  .vp-atc-row {
    display: flex;
    gap: 12px;
    align-items: stretch;
    margin: 24px 0 28px;
  }
  .vp-qty {
    display: flex;
    align-items: center;
    border: 1.5px solid #dcd7ce;
    border-radius: 50px;
    overflow: hidden;
    background: #fff;
    flex-shrink: 0;
  }
  .vp-qty-btn {
    background: none;
    border: none;
    width: 42px;
    height: 52px;
    font-size: 20px;
    font-weight: 300;
    color: #333;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .vp-qty-btn:hover { background: #f3f0eb; }
  .vp-qty-val {
    width: 36px;
    text-align: center;
    font-size: 15px;
    font-weight: 700;
    color: #1a201c;
    border: none;
    background: none;
    -moz-appearance: textfield;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .vp-qty-val::-webkit-outer-spin-button,
  .vp-qty-val::-webkit-inner-spin-button { -webkit-appearance: none; }

  .vp-atc-btn {
    flex: 1;
    height: 52px;
    background: #FF7A42;
    color: #fff;
    border: none;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 800;
    cursor: pointer;
    font-family: 'Plus Jakarta Sans', sans-serif;
    transition: background 0.2s, transform 0.12s;
    letter-spacing: 0.2px;
  }
  .vp-atc-btn:hover { background: #e86a30; transform: translateY(-1px); }
  .vp-atc-btn:active { transform: translateY(0); }

  /* ════════════════════════════
     TRUST BADGES
  ════════════════════════════ */
  .vp-trust {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1.5px solid #e8e3da;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 32px;
  }
  .vp-trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
    padding: 18px 8px;
    border-right: 1.5px solid #e8e3da;
  }
  .vp-trust-item:last-child { border-right: none; }
  .vp-trust-svg { color: #4A5D4E; }
  .vp-trust-text {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    color: #4A5D4E;
    line-height: 1.4;
  }

  /* ════════════════════════════
     FULL DESCRIPTION
  ════════════════════════════ */
  .vp-full-desc {
    border-top: 1px solid #e8e3da;
    padding-top: 28px;
    font-size: 14px;
    line-height: 1.75;
    color: #555;
  }
  .vp-full-desc img,
  .vp-full-desc iframe { display: none !important; }
  .vp-full-desc p { margin-bottom: 12px; }
  .vp-full-desc ul { padding-left: 18px; margin-bottom: 12px; }
  .vp-full-desc li { margin-bottom: 5px; }
  .vp-full-desc h2,
  .vp-full-desc h3 {
    font-size: 17px;
    font-weight: 700;
    color: #1a201c;
    margin: 18px 0 8px;
  }

  /* ════════════════════════════
     STICKY MOBILE ATC BAR
  ════════════════════════════ */
  .vp-sticky-atc {
    display: none;
    position: fixed;
    top: 72px;
    left: 0;
    right: 0;
    z-index: 300;
    background: #fff;
    border-bottom: 1px solid #e8e3da;
    padding: 12px 20px;
    gap: 12px;
    align-items: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }
  .vp-sticky-info { flex: 1; overflow: hidden; }
  .vp-sticky-name {
    font-size: 13px;
    font-weight: 700;
    color: #1a201c;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .vp-sticky-price { font-size: 12px; color: #777; }
  .vp-sticky-btn {
    background: #FF7A42;
    color: #fff;
    border: none;
    border-radius: 50px;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 800;
    cursor: pointer;
    font-family: 'Plus Jakarta Sans', sans-serif;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ════════════════════════════
     RESPONSIVE — TABLET
  ════════════════════════════ */
  @media (max-width: 900px) {
    .vp-inner { padding: 0 24px; }
    .vp-cols {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .vp-prod-title { font-size: 26px; }
    .vp-price-tag { font-size: 22px; }
    .vp-crumb { padding: 16px 0 20px; }
  }

  /* ════════════════════════════
     RESPONSIVE — MOBILE
  ════════════════════════════ */
  @media (max-width: 600px) {
    .vp-inner { padding: 0 16px; }
    .vp-crumb { display: none; }

    /* Show sticky top bar instead */
    .vp-mobile-topbar { display: flex; }

    /* Full-bleed main image on mobile */
    .vp-main-wrap { border-radius: 12px; }
    .vp-swipe-hint { display: block; }

    .vp-prod-title { font-size: 22px; margin-bottom: 12px; }
    .vp-price-tag { font-size: 20px; }
    .vp-review-count { font-size: 12px; }
    .vp-short-desc { font-size: 13px; }

    .vp-size-pill { padding: 7px 14px; font-size: 12px; }
    .vp-color-swatch { width: 30px; height: 30px; }

    /* Stack qty + ATC vertically */
    .vp-atc-row { flex-direction: column; }
    .vp-qty { width: 100%; justify-content: space-between; }
    .vp-atc-btn { width: 100%; }

    /* Sticky ATC bar at bottom */
    .vp-sticky-atc { display: flex; }
    .vp-wrap { padding-bottom: 80px; }

    /* Thumbnails: 4 in a row but smaller */
    .vp-thumbs-row { gap: 6px; }
    
    .vp-gallery-trust {
      margin-top: 24px !important;
      padding: 16px !important;
    }

    /* Trust badges: 1 per row on very small */
    .vp-trust { grid-template-columns: 1fr 1fr; }
    .vp-trust-item:nth-child(1),
    .vp-trust-item:nth-child(2) { border-bottom: 1.5px solid #e8e3da; }
    .vp-trust-item:nth-child(2) { border-right: none; }
    .vp-trust-item:last-child { grid-column: span 2; }
  }
</style>

<!-- ═══════════ STICKY MOBILE TOP BAR ═══════════ -->
<div class="vp-mobile-topbar">
  <a href="{{ collection.url | default: '/collections/all' }}" class="vp-mobile-back">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
    Back
  </a>
  <div class="vp-mobile-title">{{ product.title }}</div>
  <div class="vp-mobile-price">{{ product.price | money }}</div>
</div>

<div class="vp-wrap">
  <div class="vp-inner">

    <!-- ─── BREADCRUMB (desktop) ─── -->
    <nav class="vp-crumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="vp-crumb-sep">/</span>
      <a href="{{ collection.url | default: '/collections/all' }}">{{ collection.title | default: 'All Products' }}</a>
      <span class="vp-crumb-sep">/</span>
      <span class="vp-crumb-current">{{ product.title | truncate: 40 }}</span>
    </nav>

    <div class="vp-cols">

      <!-- ══════════ GALLERY ══════════ -->
      <div class="vp-gallery">
        <div class="vp-main-wrap">
          <img id="VpMainImg"
               src="{{ product.featured_image | img_url: '1024x1024' }}"
               alt="{{ product.title | escape }}">
          <div class="vp-swipe-hint">Tap thumbnails to switch</div>
        </div>

        {% if product.media.size > 1 %}
          <div class="vp-thumbs-row">
            {% assign shown = 0 %}
            {% for media in product.media %}
              {% if media.media_type == 'image' and shown < 4 %}
                <img class="vp-thumb {% if forloop.first %}active{% endif %}"
                     src="{{ media | img_url: '300x300', crop: 'center' }}"
                     data-full="{{ media | img_url: '1024x1024' }}"
                     alt="{{ media.alt | default: product.title | escape }}"
                     onclick="vpSwap(this)">
                {% assign shown = shown | plus: 1 %}
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        <!-- Vaezyth Care Promise -->
        <div class="vp-gallery-trust" style="margin-top: 32px; background: #fbfaf8; border-radius: 12px; padding: 24px; border: 1px solid #e6e3dd;">
          <h4 style="font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 700; color: #1c1917; margin: 0 0 16px 0; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #e6e3dd; padding-bottom: 12px;">Vaezyth Care Promise</h4>
          
          <div style="display: flex; flex-direction: column; gap: 16px; text-align: left;">
            <!-- Guarantee -->
            <div style="display: flex; gap: 12px; align-items: flex-start;">
              <div style="color: #4A5D4E; margin-top: 2px; flex-shrink: 0;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
              </div>
              <div>
                <h5 style="font-size: 13px; font-weight: 700; color: #1c1917; margin: 0 0 2px 0;">30-Day Risk-Free Trial</h5>
                <p style="font-size: 12px; color: #666; margin: 0; line-height: 1.4;">If you or your companion aren't 100% satisfied, returns are simple and hassle-free.</p>
              </div>
            </div>
            
            <!-- Shipping -->
            <div style="display: flex; gap: 12px; align-items: flex-start;">
              <div style="color: #4A5D4E; margin-top: 2px; flex-shrink: 0;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="1" y="3" width="15" height="13" rx="2" ry="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              </div>
              <div>
                <h5 style="font-size: 13px; font-weight: 700; color: #1c1917; margin: 0 0 2px 0;">Free Tracked Shipping</h5>
                <p style="font-size: 12px; color: #666; margin: 0; line-height: 1.4;">Enjoy free delivery on all orders over £30. All orders are processed and prepared for shipping within 48–72 hours with full tracking.</p>
              </div>
            </div>

            <!-- Security -->
            <div style="display: flex; gap: 12px; align-items: flex-start;">
              <div style="color: #4A5D4E; margin-top: 2px; flex-shrink: 0;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </div>
              <div>
                <h5 style="font-size: 13px; font-weight: 700; color: #1c1917; margin: 0 0 2px 0;">Safe & Secure Checkout</h5>
                <p style="font-size: 12px; color: #666; margin: 0; line-height: 1.4;">All transactions are fully encrypted and securely processed via standard payment gateways.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ══════════ PRODUCT INFO ══════════ -->
      <div class="vp-info-col">

        <h1 class="vp-prod-title">{{ product.title }}</h1>

        <!-- Stars + Price -->
        <div class="vp-rating-price">
          <span class="vp-stars">★★★★★</span>
          <span class="vp-review-count">4.8/5 &nbsp;(124 reviews)</span>
          <div>
            <span class="vp-price-tag" id="VpPrice">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
              <span class="vp-compare-tag">{{ product.compare_at_price | money }}</span>
            {% endif %}
          </div>
        </div>

        <div class="vp-divider"></div>

        {% form 'product', product %}
          <input type="hidden" name="id" id="VpVariantId" value="{{ product.variants.first.id }}">

          {% unless product.has_only_default_variant %}
            {% for option in product.options_with_values %}
              {% assign d_name = option.name | downcase %}
              {% assign is_color = false %}
              {% if d_name contains 'color' or d_name contains 'colour' %}
                {% assign is_color = true %}
              {% endif %}

              <div class="vp-opt-block">
                <div class="vp-opt-header">
                  <span class="vp-opt-name">
                    {{ option.name }}:&nbsp;<span class="vp-opt-selected" id="VpLabel{{ forloop.index }}">{{ option.selected_value }}</span>
                  </span>
                  {% if option.name == 'Size' or option.name == 'Length' %}
                    <a href="#" class="vp-size-guide">Size Guide</a>
                  {% endif %}
                </div>
                <div class="vp-opt-values">
                  {% for value in option.values %}
                    {% if is_color %}
                      {% assign swatch_bg = value | downcase | remove: ' ' %}
                      {% assign variant_img = blank %}
                      {% for v in product.variants %}
                        {% if v.options contains value and v.featured_image %}
                          {% assign variant_img = v.featured_image | img_url: '60x60', crop: 'center' %}
                          {% break %}
                        {% endif %}
                      {% endfor %}

                      <button type="button"
                              class="vp-color-swatch {% if option.selected_value == value %}active{% endif %}"
                              style="{% if variant_img != blank %}background-image: url('{{ variant_img }}'); background-size: cover;{% else %}background-color: {{ swatch_bg }};{% endif %}"
                              data-value="{{ value | escape }}"
                              data-opt="{{ forloop.parentloop.index }}"
                              title="{{ value }}"
                              onclick="vpPick(this, {{ forloop.parentloop.index }})">
                      </button>
                    {% else %}
                      <button type="button"
                              class="vp-size-pill {% if option.selected_value == value %}active{% endif %}"
                              data-value="{{ value | escape }}"
                              data-opt="{{ forloop.parentloop.index }}"
                              onclick="vpPick(this, {{ forloop.parentloop.index }})">
                        {{ value }}
                      </button>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          {% endunless %}

          <!-- Qty + ATC -->
          <div class="vp-atc-row">
            <div class="vp-qty">
              <button type="button" class="vp-qty-btn" onclick="vpQty(-1)">−</button>
              <input type="number" class="vp-qty-val" name="quantity" id="VpQty" value="1" min="1">
              <button type="button" class="vp-qty-btn" onclick="vpQty(1)">+</button>
            </div>
            <button type="submit" name="add" class="vp-atc-btn" id="VpAtcBtn">Add to Cart</button>
          </div>

        {% endform %}

        <!-- Trust Badges -->
        <div class="vp-trust">
          <div class="vp-trust-item">
            <div class="vp-trust-svg">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            </div>
            <div class="vp-trust-text">Eco-friendly<br>veg leather</div>
          </div>
          <div class="vp-trust-item">
            <div class="vp-trust-svg">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div class="vp-trust-text">Reinforced<br>stitching</div>
          </div>
          <div class="vp-trust-item">
            <div class="vp-trust-svg">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <div class="vp-trust-text">Solid brass<br>hardware</div>
          </div>
        </div>

        <!-- Full Description -->
        <div class="vp-full-desc">
          {% assign desc = product.description %}
          {% assign final_desc = desc %}
          
          {% if desc contains 'Packing List' %}
            {% assign desc_parts = desc | split: 'Packing List' %}
            {% assign final_desc = desc_parts[0] %}
          {% elsif desc contains 'Packing list' %}
            {% assign desc_parts = desc | split: 'Packing list' %}
            {% assign final_desc = desc_parts[0] %}
          {% endif %}
          
          {{ final_desc | replace: '<p>&nbsp;</p>', '' | replace: '<p><br></p>', '' | replace: '<p><br/></p>', '' | replace: '<br><br><br>', '<br>' | replace: '<br><br>', '<br>' }}
        </div>

      </div>
    </div>
  </div>
</div>

<!-- ═══════════ STICKY MOBILE ATC BAR ═══════════ -->
<div class="vp-sticky-atc" id="VpStickyBar">
  <div class="vp-sticky-info">
    <div class="vp-sticky-name">{{ product.title }}</div>
    <div class="vp-sticky-price" id="VpStickyPrice">{{ product.price | money }}</div>
  </div>
  <button class="vp-sticky-btn" onclick="document.getElementById('VpAtcBtn').click()" style="padding: 12px 14px; font-size: 12px;">
    Add to Cart
  </button>
  <button class="vp-sticky-btn" onclick="window.location.href='/checkout'" style="background:#111; padding: 12px 14px; font-size: 12px;">
    Checkout
  </button>
</div>

<script id="vp-json" type="application/json">{{ product.variants | json }}</script>

<script>
  // Swap main image on thumbnail click
  function vpSwap(el) {
    document.getElementById('VpMainImg').src = el.dataset.full;
    document.querySelectorAll('.vp-thumb').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
  }

  // Quantity controls
  function vpQty(d) {
    const inp = document.getElementById('VpQty');
    inp.value = Math.max(1, parseInt(inp.value || 1) + d);
  }

  // Variant picker
  function vpPick(el, optIdx) {
    el.closest('.vp-opt-values').querySelectorAll('.vp-size-pill, .vp-color-swatch')
      .forEach(b => b.classList.remove('active'));
    el.classList.add('active');

    const label = document.getElementById('VpLabel' + optIdx);
    if (label) label.textContent = el.dataset.value;

    const selected = [];
    document.querySelectorAll('.vp-opt-block').forEach(g => {
      const a = g.querySelector('.active');
      selected.push(a ? a.dataset.value : null);
    });

    const variants = JSON.parse(document.getElementById('vp-json').textContent);
    const match = variants.find(v => v.options.every((o, i) => o === selected[i]));
    if (match) {
      document.getElementById('VpVariantId').value = match.id;
      const price = '£' + (match.price / 100).toFixed(2);
      const p = document.getElementById('VpPrice');
      const sp = document.getElementById('VpStickyPrice');
      if (p) p.textContent = price;
      if (sp) sp.textContent = price;
      if (match.featured_image) document.getElementById('VpMainImg').src = match.featured_image.src;
    }
  }

  // Hide sticky bar when ATC button is visible
  (function() {
    const atcBtn = document.getElementById('VpAtcBtn');
    const stickyBar = document.getElementById('VpStickyBar');
    if (!atcBtn || !stickyBar) return;
    const obs = new IntersectionObserver(([e]) => {
      stickyBar.style.opacity = e.isIntersecting ? '0' : '1';
      stickyBar.style.pointerEvents = e.isIntersecting ? 'none' : 'all';
    }, { threshold: 0.5 });
    obs.observe(atcBtn);
  })();
</script>

{% schema %}
{ "name": "Main Product", "settings": [] }
{% endschema %}
