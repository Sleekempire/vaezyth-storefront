{% comment %} Vaezyth – Main Product Section {% endcomment %}

<style>
  /* ── Reset & Base ── */
  .vp-wrap {
    background: #faf8f4;
    padding: 32px 0 80px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #1a201c;
  }
  .vp-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── Breadcrumb ── */
  .vp-crumb {
    font-size: 11px;
    color: #999;
    margin-bottom: 28px;
    letter-spacing: 0.2px;
  }
  .vp-crumb a { color: #999; text-decoration: none; }
  .vp-crumb a:hover { color: #555; }

  /* ── Two-column layout ── */
  .vp-cols {
    display: grid;
    grid-template-columns: 56% 44%;
    gap: 56px;
    align-items: start;
  }

  /* ─────── LEFT: Gallery ─────── */
  .vp-gallery { display: flex; flex-direction: column; gap: 14px; }

  .vp-main-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 16px;
    overflow: hidden;
    background: #ede9e2;
  }
  #VpMainImg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .vp-main-wrap:hover #VpMainImg { transform: scale(1.04); }

  .vp-thumbs-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  .vp-thumb {
    aspect-ratio: 1;
    border-radius: 10px;
    object-fit: cover;
    cursor: pointer;
    border: 2.5px solid transparent;
    background: #ede9e2;
    transition: border-color 0.2s;
    width: 100%;
    display: block;
  }
  .vp-thumb.active,
  .vp-thumb:hover { border-color: #d97706; }

  /* ─────── RIGHT: Info ─────── */
  .vp-info-col { padding-top: 4px; }

  .vp-prod-title {
    font-family: 'Outfit', sans-serif;
    font-size: 34px;
    font-weight: 700;
    line-height: 1.2;
    color: #1a201c;
    margin: 0 0 14px;
  }

  /* Stars + Price row */
  .vp-rating-price {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .vp-stars-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .vp-star { color: #f59e0b; font-size: 15px; }
  .vp-rating-count {
    font-size: 13px;
    color: #777;
  }
  .vp-price-tag {
    font-family: 'Outfit', sans-serif;
    font-size: 26px;
    font-weight: 700;
    color: #1a201c;
    margin-left: auto;
  }
  .vp-compare-tag {
    font-size: 14px;
    color: #bbb;
    text-decoration: line-through;
    margin-left: 6px;
    font-weight: 400;
  }

  /* Short description */
  .vp-short-desc {
    font-size: 13.5px;
    line-height: 1.65;
    color: #666;
    margin-bottom: 24px;
    border-bottom: 1px solid #e8e3da;
    padding-bottom: 24px;
  }

  /* ── Options ── */
  .vp-opt-block { margin-bottom: 20px; }
  .vp-opt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .vp-opt-name {
    font-size: 13px;
    font-weight: 700;
    color: #1a201c;
  }
  .vp-opt-selected {
    font-weight: 400;
    color: #888;
    font-size: 13px;
  }
  .vp-size-guide {
    font-size: 11px;
    font-weight: 700;
    color: #4A5D4E;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-decoration: none;
  }
  .vp-size-guide:hover { text-decoration: underline; }

  .vp-opt-values { display: flex; flex-wrap: wrap; gap: 8px; }

  /* Text pills */
  .vp-size-pill {
    padding: 8px 18px;
    border: 1.5px solid #d5d0c8;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #444;
    background: #fff;
    cursor: pointer;
    transition: all 0.18s;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .vp-size-pill:hover { border-color: #4A5D4E; color: #4A5D4E; }
  .vp-size-pill.active {
    border-color: #1a201c;
    background: #1a201c;
    color: #fff;
  }

  /* Color swatches */
  .vp-color-swatch {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    cursor: pointer;
    border: 3px solid transparent;
    box-shadow: 0 0 0 1.5px #ccc;
    transition: box-shadow 0.18s;
    padding: 0;
    display: inline-block;
  }
  .vp-color-swatch:hover { box-shadow: 0 0 0 2px #4A5D4E; }
  .vp-color-swatch.active {
    box-shadow: 0 0 0 2.5px #1a201c;
    border-color: #faf8f4;
  }

  /* ── Qty + ATC row ── */
  .vp-atc-row {
    display: flex;
    gap: 12px;
    align-items: stretch;
    margin-bottom: 28px;
    margin-top: 24px;
  }
  .vp-qty {
    display: flex;
    align-items: center;
    border: 1.5px solid #dcd7ce;
    border-radius: 50px;
    overflow: hidden;
    background: #fff;
    flex-shrink: 0;
  }
  .vp-qty-btn {
    background: none;
    border: none;
    width: 40px;
    height: 52px;
    font-size: 20px;
    font-weight: 300;
    color: #333;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .vp-qty-btn:hover { background: #f3f0eb; }
  .vp-qty-val {
    width: 36px;
    text-align: center;
    font-size: 15px;
    font-weight: 700;
    color: #1a201c;
    border: none;
    background: none;
    -moz-appearance: textfield;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .vp-qty-val::-webkit-outer-spin-button,
  .vp-qty-val::-webkit-inner-spin-button { -webkit-appearance: none; }

  .vp-atc-btn {
    flex: 1;
    height: 52px;
    background: #FF7A42;
    color: #fff;
    border: none;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 800;
    cursor: pointer;
    letter-spacing: 0.2px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    transition: background 0.2s, transform 0.12s;
  }
  .vp-atc-btn:hover {
    background: #e86a30;
    transform: translateY(-1px);
  }

  /* ── Trust badges ── */
  .vp-trust {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1.5px solid #e8e3da;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 36px;
  }
  .vp-trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 7px;
    padding: 18px 8px;
    border-right: 1.5px solid #e8e3da;
  }
  .vp-trust-item:last-child { border-right: none; }
  .vp-trust-svg { color: #4A5D4E; }
  .vp-trust-text {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    color: #4A5D4E;
    line-height: 1.4;
  }

  /* ── Full description ── */
  .vp-full-desc {
    border-top: 1px solid #e8e3da;
    padding-top: 28px;
    font-size: 14px;
    line-height: 1.75;
    color: #555;
  }
  .vp-full-desc img,
  .vp-full-desc iframe { display: none !important; }
  .vp-full-desc p { margin-bottom: 12px; }
  .vp-full-desc ul { padding-left: 18px; margin-bottom: 12px; }
  .vp-full-desc li { margin-bottom: 5px; }
  .vp-full-desc h2,
  .vp-full-desc h3 {
    font-size: 17px;
    font-weight: 700;
    color: #1a201c;
    margin: 18px 0 8px;
  }

  /* ── Responsive ── */
  @media (max-width: 880px) {
    .vp-inner { padding: 0 20px; }
    .vp-cols {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .vp-prod-title { font-size: 26px; }
    .vp-price-tag { font-size: 22px; }
    .vp-atc-row { flex-direction: column; }
    .vp-qty { width: 100%; justify-content: space-between; }
  }
  @media (max-width: 480px) {
    .vp-thumbs-row { grid-template-columns: repeat(4, 1fr); gap: 6px; }
    .vp-trust { grid-template-columns: 1fr 1fr; }
    .vp-trust-item:nth-child(2) { border-right: none; }
    .vp-trust-item:nth-child(1),
    .vp-trust-item:nth-child(2) {
      border-bottom: 1.5px solid #e8e3da;
    }
    .vp-trust-item:last-child { grid-column: span 2; border-right: none; }
  }
</style>

<div class="vp-wrap">
  <div class="vp-inner">

    <!-- Breadcrumb -->
    <div class="vp-crumb">
      <a href="/">Shop</a> /
      <a href="{{ collection.url | default: '/collections/all' }}">{{ collection.title | default: 'Products' }}</a> /
      {{ product.title | truncate: 30 }}
    </div>

    <div class="vp-cols">

      <!-- ══ LEFT: Gallery ══ -->
      <div class="vp-gallery">
        <div class="vp-main-wrap">
          <img id="VpMainImg"
               src="{{ product.featured_image | img_url: '1024x1024' }}"
               alt="{{ product.title | escape }}">
        </div>

        {% if product.media.size > 0 %}
        <div class="vp-thumbs-row">
          {% assign shown = 0 %}
          {% for media in product.media %}
            {% if media.media_type == 'image' and shown < 4 %}
              <img class="vp-thumb {% if forloop.first %}active{% endif %}"
                   src="{{ media | img_url: '300x300', crop: 'center' }}"
                   data-full="{{ media | img_url: '1024x1024' }}"
                   alt="{{ media.alt | default: product.title | escape }}"
                   onclick="vpSwap(this)">
              {% assign shown = shown | plus: 1 %}
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>

      <!-- ══ RIGHT: Info ══ -->
      <div class="vp-info-col">

        <h1 class="vp-prod-title">{{ product.title }}</h1>

        <!-- Stars + Price -->
        <div class="vp-rating-price">
          <div class="vp-stars-wrap">
            <span class="vp-star">★★★★★</span>
            <span class="vp-rating-count">4.8/5 (124 reviews)</span>
          </div>
          <div>
            <span class="vp-price-tag" id="VpPrice">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
              <span class="vp-compare-tag">{{ product.compare_at_price | money }}</span>
            {% endif %}
          </div>
        </div>

        <!-- Short description -->
        <div class="vp-short-desc">
          {{ product.description | strip_html | truncatewords: 40 }}
        </div>

        {% form 'product', product %}
          <input type="hidden" name="id" id="VpVariantId" value="{{ product.variants.first.id }}">

          <!-- Variant Options -->
          {% unless product.has_only_default_variant %}
            {% for option in product.options_with_values %}
              {% assign d_name = option.name | downcase %}
              {% assign is_color = false %}
              {% if d_name contains 'color' or d_name contains 'colour' %}
                {% assign is_color = true %}
              {% endif %}

              <div class="vp-opt-block">
                <div class="vp-opt-header">
                  <span class="vp-opt-name">
                    {{ option.name }}: <span class="vp-opt-selected" id="VpLabel{{ forloop.index }}">{{ option.selected_value }}</span>
                  </span>
                  {% if option.name == 'Size' or option.name == 'Length' %}
                    <a href="#" class="vp-size-guide">Size Guide</a>
                  {% endif %}
                </div>
                <div class="vp-opt-values">
                  {% for value in option.values %}
                    {% if is_color %}
                      <button type="button"
                              class="vp-color-swatch {% if option.selected_value == value %}active{% endif %}"
                              style="background-color: {{ value | downcase | remove: ' ' }};"
                              data-value="{{ value | escape }}"
                              data-opt="{{ forloop.parentloop.index }}"
                              title="{{ value }}"
                              onclick="vpPick(this, {{ forloop.parentloop.index }})">
                      </button>
                    {% else %}
                      <button type="button"
                              class="vp-size-pill {% if option.selected_value == value %}active{% endif %}"
                              data-value="{{ value | escape }}"
                              data-opt="{{ forloop.parentloop.index }}"
                              onclick="vpPick(this, {{ forloop.parentloop.index }})">
                        {{ value }}
                      </button>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          {% endunless %}

          <!-- Qty + Add to Cart -->
          <div class="vp-atc-row">
            <div class="vp-qty">
              <button type="button" class="vp-qty-btn" onclick="vpQty(-1)">−</button>
              <input type="number" class="vp-qty-val" name="quantity" id="VpQty" value="1" min="1">
              <button type="button" class="vp-qty-btn" onclick="vpQty(1)">+</button>
            </div>
            <button type="submit" name="add" class="vp-atc-btn">Add to Cart</button>
          </div>

        {% endform %}

        <!-- Trust Badges -->
        <div class="vp-trust">
          <div class="vp-trust-item">
            <div class="vp-trust-svg">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            </div>
            <div class="vp-trust-text">Eco-friendly<br>veg leather</div>
          </div>
          <div class="vp-trust-item">
            <div class="vp-trust-svg">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div class="vp-trust-text">Reinforced<br>stitching</div>
          </div>
          <div class="vp-trust-item">
            <div class="vp-trust-svg">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <div class="vp-trust-text">Solid brass<br>hardware</div>
          </div>
        </div>

        <!-- Full Description -->
        <div class="vp-full-desc">{{ product.description }}</div>

      </div><!-- /info -->
    </div><!-- /cols -->
  </div><!-- /inner -->
</div><!-- /wrap -->

<script id="vp-json" type="application/json">{{ product.variants | json }}</script>

<script>
  function vpSwap(el) {
    document.getElementById('VpMainImg').src = el.dataset.full;
    document.querySelectorAll('.vp-thumb').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
  }

  function vpQty(d) {
    const inp = document.getElementById('VpQty');
    inp.value = Math.max(1, parseInt(inp.value || 1) + d);
  }

  function vpPick(el, optIdx) {
    el.closest('.vp-opt-values').querySelectorAll('.vp-size-pill, .vp-color-swatch').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
    const label = document.getElementById('VpLabel' + optIdx);
    if (label) label.textContent = el.dataset.value;

    const selected = [];
    document.querySelectorAll('.vp-opt-block').forEach(g => {
      const a = g.querySelector('.active');
      selected.push(a ? a.dataset.value : null);
    });

    const variants = JSON.parse(document.getElementById('vp-json').textContent);
    const match = variants.find(v => v.options.every((o, i) => o === selected[i]));
    if (match) {
      document.getElementById('VpVariantId').value = match.id;
      const p = document.getElementById('VpPrice');
      if (p) p.textContent = '£' + (match.price / 100).toFixed(2);
      if (match.featured_image) document.getElementById('VpMainImg').src = match.featured_image.src;
    }
  }
</script>

{% schema %}
{ "name": "Main Product", "settings": [] }
{% endschema %}
