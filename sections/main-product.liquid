{% comment %} Vaezyth – Main Product Section {% endcomment %}

<style>
  /* ── Page Wrapper ── */
  .vp-page {
    background: #FAF8F5;
    padding: 48px 0 80px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .vp-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ── Breadcrumb ── */
  .vp-breadcrumb {
    font-size: 12px;
    color: #888;
    margin-bottom: 32px;
    letter-spacing: 0.3px;
  }
  .vp-breadcrumb a { color: #888; text-decoration: none; }
  .vp-breadcrumb a:hover { color: #4A5D4E; }
  .vp-breadcrumb span { color: #333; font-weight: 600; }

  /* ── Two Column Grid ── */
  .vp-grid {
    display: grid;
    grid-template-columns: 55% 45%;
    gap: 64px;
    align-items: start;
  }

  /* ── Gallery ── */
  .vp-gallery { display: flex; flex-direction: column; gap: 16px; }

  .vp-main-img-wrap {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 20px;
    overflow: hidden;
    background: #f0eee9;
  }
  .vp-main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }
  .vp-main-img-wrap:hover .vp-main-img { transform: scale(1.03); }

  .vp-thumbs {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding-bottom: 4px;
    scrollbar-width: none;
  }
  .vp-thumbs::-webkit-scrollbar { display: none; }

  .vp-thumb {
    flex: 0 0 calc(25% - 8px);
    aspect-ratio: 1;
    border-radius: 10px;
    object-fit: cover;
    cursor: pointer;
    border: 2px solid transparent;
    background: #f0eee9;
    transition: border-color 0.2s;
  }
  .vp-thumb.active,
  .vp-thumb:hover { border-color: #FF7A42; }

  /* ── Product Info ── */
  .vp-info { display: flex; flex-direction: column; }

  .vp-title {
    font-family: 'Outfit', sans-serif;
    font-size: 36px;
    font-weight: 700;
    line-height: 1.2;
    color: #1a201c;
    margin: 0 0 20px;
  }

  .vp-meta-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .vp-price {
    font-family: 'Outfit', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: #3b4d40;
  }
  .vp-compare-price {
    font-size: 16px;
    color: #aaa;
    text-decoration: line-through;
  }
  .vp-reviews {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #777;
    padding-left: 16px;
    border-left: 1px solid #e0ddd7;
  }
  .vp-stars { color: #FF7A42; letter-spacing: 2px; }

  .vp-divider {
    height: 1px;
    background: #e8e4de;
    margin: 24px 0;
  }

  .vp-short-desc {
    font-size: 15px;
    line-height: 1.7;
    color: #555;
    margin-bottom: 28px;
  }

  /* ── Options ── */
  .vp-option-group { margin-bottom: 24px; }
  .vp-option-label {
    font-size: 13px;
    font-weight: 700;
    color: #1a201c;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .vp-option-selected {
    font-weight: 400;
    color: #777;
  }
  .vp-option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  /* Text pills */
  .vp-pill {
    padding: 10px 22px;
    border: 1.5px solid #dcd7ce;
    border-radius: 8px;
    color: #444;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    background: #fff;
    transition: all 0.2s;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .vp-pill:hover { border-color: #4A5D4E; color: #4A5D4E; }
  .vp-pill.active {
    border-color: #4A5D4E;
    background: #4A5D4E;
    color: #fff;
  }

  /* Color swatches */
  .vp-swatch {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    border: 3px solid transparent;
    box-shadow: 0 0 0 1.5px #dcd7ce;
    transition: box-shadow 0.2s;
    padding: 0;
  }
  .vp-swatch:hover { box-shadow: 0 0 0 2px #4A5D4E; }
  .vp-swatch.active { box-shadow: 0 0 0 2.5px #4A5D4E; border-color: white; }

  /* ── Buy Row ── */
  .vp-buy-row {
    display: flex;
    gap: 12px;
    margin-bottom: 32px;
    align-items: stretch;
  }
  .vp-qty-picker {
    display: flex;
    align-items: center;
    background: #fff;
    border: 1.5px solid #e0ddd7;
    border-radius: 50px;
    overflow: hidden;
    height: 54px;
    flex-shrink: 0;
  }
  .vp-qty-btn {
    background: none;
    border: none;
    color: #333;
    font-size: 20px;
    cursor: pointer;
    width: 44px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    font-weight: 300;
  }
  .vp-qty-btn:hover { background: #f5f3ef; }
  .vp-qty-input {
    background: none;
    border: none;
    color: #1a201c;
    font-size: 16px;
    font-weight: 700;
    width: 44px;
    text-align: center;
    -moz-appearance: textfield;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .vp-qty-input::-webkit-outer-spin-button,
  .vp-qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

  .vp-btn-cart {
    flex: 1;
    height: 54px;
    background: #FF7A42;
    color: #fff;
    border: none;
    border-radius: 50px;
    font-weight: 800;
    font-size: 16px;
    cursor: pointer;
    letter-spacing: 0.3px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    transition: background 0.2s, transform 0.15s;
  }
  .vp-btn-cart:hover {
    background: #e86930;
    transform: translateY(-1px);
  }

  /* ── Trust Badges ── */
  .vp-trust {
    display: flex;
    gap: 0;
    border: 1.5px solid #e8e4de;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 36px;
  }
  .vp-trust-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 16px 8px;
    text-align: center;
    gap: 8px;
    border-right: 1.5px solid #e8e4de;
  }
  .vp-trust-item:last-child { border-right: none; }
  .vp-trust-icon { color: #4A5D4E; }
  .vp-trust-label {
    font-size: 11px;
    font-weight: 700;
    color: #4A5D4E;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.3;
  }

  /* ── Full Description ── */
  .vp-full-desc {
    border-top: 1px solid #e8e4de;
    padding-top: 32px;
    font-size: 15px;
    line-height: 1.7;
    color: #555;
  }
  .vp-full-desc img, .vp-full-desc iframe { display: none !important; }
  .vp-full-desc p { margin-bottom: 14px; }
  .vp-full-desc ul { padding-left: 20px; margin-bottom: 14px; }
  .vp-full-desc li { margin-bottom: 6px; }
  .vp-full-desc h2,
  .vp-full-desc h3 {
    font-size: 18px;
    font-weight: 700;
    color: #1a201c;
    margin: 20px 0 10px;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .vp-container { padding: 0 20px; }
    .vp-grid { grid-template-columns: 1fr; gap: 32px; }
    .vp-title { font-size: 28px; }
    .vp-price { font-size: 24px; }
    .vp-buy-row { flex-direction: column; }
    .vp-qty-picker { width: 100%; justify-content: center; }
    .vp-trust { flex-wrap: wrap; }
    .vp-trust-item { flex: 1 0 45%; border-right: none; border-bottom: 1.5px solid #e8e4de; }
    .vp-trust-item:nth-child(odd) { border-right: 1.5px solid #e8e4de; }
    .vp-trust-item:last-child { border-bottom: none; }
  }
  @media (max-width: 500px) {
    .vp-page { padding: 24px 0 60px; }
    .vp-thumb { flex: 0 0 calc(33.333% - 7px); }
  }
</style>

<div class="vp-page">
  <div class="vp-container">

    <!-- Breadcrumb -->
    <div class="vp-breadcrumb">
      <a href="/">Shop</a>
      &nbsp;/&nbsp;
      <a href="{{ collection.url | default: '/collections/all' }}">{{ collection.title | default: 'All Products' }}</a>
      &nbsp;/&nbsp;
      <span>{{ product.title | truncate: 30 }}</span>
    </div>

    <div class="vp-grid">

      <!-- ── Gallery ── -->
      <div class="vp-gallery">
        <div class="vp-main-img-wrap">
          <img id="VpMainImage" class="vp-main-img"
               src="{{ product.featured_image | img_url: '1024x1024' }}"
               alt="{{ product.title | escape }}">
        </div>

        {% if product.media.size > 1 %}
        <div class="vp-thumbs">
          {% for media in product.media %}
            {% if media.media_type == 'image' %}
              <img class="vp-thumb {% if forloop.first %}active{% endif %}"
                   src="{{ media | img_url: '300x300', crop: 'center' }}"
                   data-full="{{ media | img_url: '1024x1024' }}"
                   alt="{{ media.alt | default: product.title | escape }}"
                   onclick="vpSwapImage(this)">
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>

      <!-- ── Product Info ── -->
      <div class="vp-info">

        <h1 class="vp-title">{{ product.title }}</h1>

        <div class="vp-meta-row">
          <div>
            <span class="vp-price" id="VpPrice">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
              <span class="vp-compare-price">{{ product.compare_at_price | money }}</span>
            {% endif %}
          </div>
          <div class="vp-reviews">
            <span class="vp-stars">★★★★★</span>
            <span>4.8 &nbsp;(124 reviews)</span>
          </div>
        </div>

        <div class="vp-divider"></div>

        <p class="vp-short-desc">{{ product.description | strip_html | truncatewords: 35 }}</p>

        {% form 'product', product %}
          <input type="hidden" name="id" id="VpVariantId" value="{{ product.variants.first.id }}">

          {% unless product.has_only_default_variant %}
            {% for option in product.options_with_values %}
              <div class="vp-option-group">
                <div class="vp-option-label">
                  {{ option.name }}:&nbsp;<span class="vp-option-selected" id="VpOptionLabel{{ forloop.index }}">{{ option.selected_value }}</span>
                </div>
                <div class="vp-option-values">
                  {% assign d_name = option.name | downcase %}
                  {% for value in option.values %}
                    {% assign is_color = false %}
                    {% if d_name contains 'color' or d_name contains 'colour' %}
                      {% assign is_color = true %}
                    {% endif %}

                    {% if is_color %}
                      <button type="button"
                              class="vp-swatch {% if option.selected_value == value %}active{% endif %}"
                              style="background-color: {{ value | downcase | remove: ' ' }};"
                              data-value="{{ value | escape }}"
                              data-option-index="{{ forloop.parentloop.index }}"
                              title="{{ value }}"
                              onclick="vpSelectOption(this, {{ forloop.parentloop.index }})">
                      </button>
                    {% else %}
                      <button type="button"
                              class="vp-pill {% if option.selected_value == value %}active{% endif %}"
                              data-value="{{ value | escape }}"
                              data-option-index="{{ forloop.parentloop.index }}"
                              onclick="vpSelectOption(this, {{ forloop.parentloop.index }})">
                        {{ value }}
                      </button>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          {% endunless %}

          <!-- Quantity + Add to Cart -->
          <div class="vp-buy-row">
            <div class="vp-qty-picker">
              <button type="button" class="vp-qty-btn" onclick="vpUpdateQty(-1)">−</button>
              <input type="number" class="vp-qty-input" name="quantity" id="VpQuantity" value="1" min="1">
              <button type="button" class="vp-qty-btn" onclick="vpUpdateQty(1)">+</button>
            </div>
            <button type="submit" name="add" class="vp-btn-cart">Add to Cart</button>
          </div>

        {% endform %}

        <!-- Trust Badges -->
        <div class="vp-trust">
          <div class="vp-trust-item">
            <div class="vp-trust-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg>
            </div>
            <div class="vp-trust-label">Eco-Friendly<br>Materials</div>
          </div>
          <div class="vp-trust-item">
            <div class="vp-trust-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
            </div>
            <div class="vp-trust-label">Premium<br>Quality</div>
          </div>
          <div class="vp-trust-item">
            <div class="vp-trust-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            </div>
            <div class="vp-trust-label">Secure<br>Checkout</div>
          </div>
        </div>

        <!-- Full Description -->
        <div class="vp-full-desc">
          {{ product.description }}
        </div>

      </div>
    </div>
  </div>
</div>

<script id="vp-variants-json" type="application/json">
  {{ product.variants | json }}
</script>

<script>
  function vpSwapImage(thumb) {
    document.getElementById('VpMainImage').src = thumb.dataset.full;
    document.querySelectorAll('.vp-thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
  }

  function vpUpdateQty(delta) {
    const input = document.getElementById('VpQuantity');
    const newVal = Math.max(1, parseInt(input.value) + delta);
    input.value = newVal;
  }

  function vpSelectOption(el, optionIndex) {
    // Toggle active state
    const group = el.closest('.vp-option-values');
    group.querySelectorAll('.vp-pill, .vp-swatch').forEach(b => b.classList.remove('active'));
    el.classList.add('active');

    // Update label
    const labelEl = document.getElementById('VpOptionLabel' + optionIndex);
    if (labelEl) labelEl.textContent = el.dataset.value;

    // Collect all selected options
    const selectedOptions = [];
    document.querySelectorAll('.vp-option-group').forEach(group => {
      const active = group.querySelector('.vp-pill.active, .vp-swatch.active');
      selectedOptions.push(active ? active.dataset.value : '');
    });

    // Match variant
    const variants = JSON.parse(document.getElementById('vp-variants-json').textContent);
    const match = variants.find(v => v.options.every((opt, i) => opt === selectedOptions[i]));
    if (match) {
      document.getElementById('VpVariantId').value = match.id;
      // Update price
      const priceEl = document.getElementById('VpPrice');
      if (priceEl) {
        const amount = (match.price / 100).toFixed(2);
        priceEl.textContent = '£' + amount;
      }
      // Update image if variant has one
      if (match.featured_image) {
        document.getElementById('VpMainImage').src = match.featured_image.src;
      }
    }
  }
</script>

{% schema %}
{
  "name": "Main Product",
  "settings": []
}
{% endschema %}
