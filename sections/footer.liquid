<footer style="background-color: #f0eee9; color: #1a201c; padding: 32px 5% 0; font-family: 'Plus Jakarta Sans', sans-serif; overflow: hidden; border-top: 1px solid #e0ddd7;">
  <div style="max-width: 1200px; margin: 0 auto;">
    
    <div class="va-footer-grid" style="display: grid; grid-template-columns: 2fr 1.2fr 1.8fr; gap: 32px; margin-bottom: 32px;">
      
      <!-- Column 1: Brand -->
      <div>
        <h2 style="font-family: 'Outfit', sans-serif; font-size: 26px; font-weight: 800; letter-spacing: -0.5px; color: #4A5D4E; margin: 0 0 10px; text-transform: uppercase;">VAEZYTH</h2>
        <p style="font-size: 13px; color: #555; line-height: 1.5; max-width: 250px; margin: 0;">Premium essentials for your most loyal companions. Crafted with love and high-end materials.</p>
      </div>

      <!-- Column 2: Support -->
      <div>
        <h4 style="color: #1a201c; font-size: 14px; font-weight: 700; margin: 0 0 14px;">Support</h4>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px;">
          <li><a href="/pages/return" style="color: #555; text-decoration: none; font-size: 13px; transition: color 0.2s ease;" onmouseover="this.style.color='#4A5D4E'" onmouseout="this.style.color='#555'">Returns & Exchanges</a></li>
          <li><a href="/pages/contact" style="color: #555; text-decoration: none; font-size: 13px; transition: color 0.2s ease;" onmouseover="this.style.color='#4A5D4E'" onmouseout="this.style.color='#555'">Contact Us</a></li>
          <li><a href="/pages/faq" style="color: #555; text-decoration: none; font-size: 13px; transition: color 0.2s ease;" onmouseover="this.style.color='#4A5D4E'" onmouseout="this.style.color='#555'">FAQ</a></li>
        </ul>
      </div>

      <!-- Column 3: Join -->
      <div>
        <h4 style="color: #1a201c; font-size: 14px; font-weight: 700; margin: 0 0 8px;">Join the Family</h4>
        <p style="font-size: 12px; color: #555; margin-bottom: 14px; line-height: 1.4;">Subscribe to receive walkies tips and exclusive early access.</p>
        
        <form style="display: flex; gap: 8px; margin: 0;">
          <input type="email" placeholder="Email address" style="flex: 1; padding: 10px 14px; border: 1px solid #dcd7ce; border-radius: 8px; font-size: 13px; outline: none; font-family: 'Plus Jakarta Sans', sans-serif;">
          <button type="submit" style="background: #4A5D4E; color: #fff; border: none; padding: 0 16px; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; transition: opacity 0.2s;">Join</button>
        </form>
      </div>

    </div>

    <!-- Bottom -->
    <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #e0ddd7; padding-top: 16px; padding-bottom: 16px;">
      <p style="font-size: 11px; color: #888; margin: 0;">
        &copy; {{ 'now' | date: "%Y" }} Vaezyth. All rights reserved.
      </p>
      <div style="display: flex; gap: 24px;">
        <a href="/policies/privacy-policy" style="font-size: 11px; color: #888; text-decoration: none;">Privacy Policy</a>
        <a href="/policies/terms-of-service" style="font-size: 11px; color: #888; text-decoration: none;">Terms of Service</a>
      </div>
    </div>

  </div>
</footer>

<style>
  @media (max-width: 900px) {
    footer { padding: 40px 5% 0 !important; }
    .va-footer-grid {
      grid-template-columns: 1fr 1fr !important;
      gap: 32px !important;
    }
    .va-footer-grid > div:first-child,
    .va-footer-grid > div:last-child {
      grid-column: span 2;
    }
    .va-footer-grid > div:last-child form {
      max-width: 400px;
    }
    footer > div > div:last-child {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
