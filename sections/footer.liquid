<footer style="background-color: #0c0a09; color: #fff; padding: 32px 5% 0; font-family: 'Plus Jakarta Sans', sans-serif; overflow: hidden;">
  <div style="max-width: 1400px; margin: 0 auto;">
    
    <div style="display: grid; grid-template-columns: 1fr 1fr 1.5fr; gap: 40px; margin-bottom: 32px;">
      
      <!-- Column 1: Shop -->
      <div>
        <h4 style="color: #666; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 24px; font-weight: 700;">
          SHOP
        </h4>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px;">
          <li><a href="/" style="color: #fff; text-decoration: none; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; transition: color 0.3s ease;" onmouseover="this.style.color='#C5A880'" onmouseout="this.style.color='#fff'">HOME</a></li>
          <li><a href="/collections/all" style="color: #fff; text-decoration: none; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; transition: color 0.3s ease;" onmouseover="this.style.color='#C5A880'" onmouseout="this.style.color='#fff'">COLLECTIONS</a></li>
          <li><a href="/pages/about-us" style="color: #fff; text-decoration: none; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; transition: color 0.3s ease;" onmouseover="this.style.color='#C5A880'" onmouseout="this.style.color='#fff'">ABOUT US</a></li>
          <li><a href="/pages/contact" style="color: #fff; text-decoration: none; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; transition: color 0.3s ease;" onmouseover="this.style.color='#C5A880'" onmouseout="this.style.color='#fff'">CONTACT</a></li>
        </ul>
      </div>

      <!-- Column 2: Support -->
      <div>
        <h4 style="color: #666; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 24px; font-weight: 700;">
          SUPPORT
        </h4>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px;">
          <li><a href="/pages/faq" style="color: #fff; text-decoration: none; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; transition: color 0.3s ease;" onmouseover="this.style.color='#C5A880'" onmouseout="this.style.color='#fff'">FAQS</a></li>
          <li><a href="/policies/privacy-policy" style="color: #fff; text-decoration: none; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; transition: color 0.3s ease;" onmouseover="this.style.color='#C5A880'" onmouseout="this.style.color='#fff'">PRIVACY POLICY</a></li>
          <li><a href="/policies/terms-of-service" style="color: #fff; text-decoration: none; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; transition: color 0.3s ease;" onmouseover="this.style.color='#C5A880'" onmouseout="this.style.color='#fff'">TERMS OF SERVICE</a></li>
        </ul>
      </div>

      <!-- Column 3: Subscribe -->
      <div style="display: flex; flex-direction: column; align-items: flex-end; text-align: right;">
        <h3 class="footer-subscribe-title" style="font-family: 'Outfit', serif; font-size: 28px; font-weight: normal; margin-bottom: 12px; color: #fff;">Subscribe</h3>
        <p class="footer-subscribe-desc" style="font-size: 11px; color: #888; margin-bottom: 32px;">Join our newsletter for updates.</p>
        <div style="width: 100%; max-width: 240px; border-bottom: 1px solid rgba(255,255,255,0.2); display: flex; align-items: center; padding-bottom: 8px;">
          <input type="email" placeholder="Your email" style="background: transparent; border: none; outline: none; color: #fff; font-size: 12px; width: 100%; font-family: 'Plus Jakarta Sans', sans-serif;">
          <button style="background: transparent; border: none; color: #fff; cursor: pointer; padding: 0;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          </button>
        </div>
      </div>

    </div>

    <!-- Copyright Section -->
    <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 24px; padding-bottom: 24px; text-align: center;">
      <p style="font-size: 11px; color: #666; margin: 0; letter-spacing: 0.5px;">
        &copy; {{ 'now' | date: "%Y" }} Vaezyth. All Rights Reserved.
      </p>
    </div>

  </div>
</footer>

<style>
  @media (max-width: 900px) {
    footer {
      padding: 24px 5% 0 !important;
    }
    footer > div > div:first-child {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 16px !important;
      margin-bottom: 16px !important;
    }
    footer > div > div:first-child > div:last-child {
      grid-column: span 2;
      align-items: flex-start !important;
      text-align: left !important;
      margin-top: 8px;
    }
    .footer-subscribe-title { font-size: 16px !important; margin-bottom: 4px !important; }
    .footer-subscribe-desc { margin-bottom: 8px !important; font-size: 10px !important; }
    footer h4 { margin-bottom: 12px !important; }
    footer ul { gap: 8px !important; }
    footer > div > div:last-child {
      padding-top: 16px !important;
      padding-bottom: 16px !important;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
