<div class="collection-hero-section" style="position: relative; width: 100%; padding: 60px 24px; display: flex; align-items: center; justify-content: center; background-color: var(--bg-hero); border-bottom: 1px solid rgba(255,255,255,0.1);">
  <div style="position: relative; z-index: 1; text-align: center; max-width: 600px;">
    {% if section.settings.logo_image %}
      <img src="{{ section.settings.logo_image | img_url: 'master' }}" alt="{{ collection.title }}" style="max-width: 240px; height: auto; margin-bottom: 24px;">
    {% else %}
      <h1 style="font-family: 'Outfit', serif; font-size: clamp(24px, 3vw, 32px); font-weight: 800; color: #ffffff; margin-bottom: 16px; letter-spacing: -1px; text-transform: uppercase;">
        {{ collection.title | default: 'All Products' }}
      </h1>
    {% endif %}
    
    {% if collection.description != blank %}
      <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 15px; color: #aaaaaa; line-height: 1.6;">
        {{ collection.description }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Collection Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Banner Logo (Optional)",
      "info": "Upload your logo here to display it instead of the collection title."
    }
  ],
  "presets": [
    {
      "name": "Collection Banner"
    }
  ]
}
{% endschema %}
