<!-- Collection Banner removed to avoid redundant PRODUCTS heading -->
<div style="display: none;">
  {% if section.settings.logo_image %}
    <img src="{{ section.settings.logo_image | img_url: 'master' }}" alt="{{ collection.title }}">
  {% else %}
    <h1>{{ collection.title | default: 'All Products' }}</h1>
  {% endif %}
</div>

{% schema %}
{
  "name": "Collection Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Banner Logo (Optional)",
      "info": "Upload your logo here to display it instead of the collection title."
    }
  ],
  "presets": [
    {
      "name": "Collection Banner"
    }
  ]
}
{% endschema %}
