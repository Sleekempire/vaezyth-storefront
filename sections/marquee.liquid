<style>
  .marquee-container {
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    background: #1c1917;
    color: #fff;
    padding: 12px 0;
    overflow: hidden;
    position: relative;
    border-top: 1px solid #333;
    border-bottom: 1px solid #333;
  }
  
  .marquee-content {
    display: flex;
    white-space: nowrap;
    animation: scroll-marquee 20s linear infinite;
  }
  
  .marquee-item {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 0 40px;
    display: inline-flex;
    align-items: center;
  }
  
  .marquee-item span {
    color: rgba(255, 255, 255, 0.4);
    margin: 0 40px;
  }

  @keyframes scroll-marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<div class="marquee-container fade-in">
  <div class="marquee-content">
    {% for i in (1..8) %}
      <div class="marquee-item">
        FREE SHIPPING WORLDWIDE <span>✦</span> 
        PREMIUM PET GEAR <span>✦</span> 
        DESIGNED FOR MODERN HOMES <span>✦</span> 
        30-DAY RETURNS
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Marquee Ticker",
  "settings": [],
  "presets": [
    {
      "name": "Marquee Ticker"
    }
  ]
}
{% endschema %}
