{% comment %} Vaezyth – Complete the Look / Product Recommendations {% endcomment %}

<style>
  .va-look-section {
    background: #faf8f4;
    padding: 0 0 80px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .va-look-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 48px 0;
    border-top: 1px solid #e8e3da;
  }

  .va-look-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 28px;
    gap: 16px;
  }
  .va-look-titles h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 26px;
    font-weight: 700;
    color: #1a201c;
    margin: 0 0 4px;
  }
  .va-look-titles p {
    font-size: 13px;
    color: #888;
    margin: 0;
  }
  .va-look-all {
    font-size: 13px;
    font-weight: 700;
    color: #4A5D4E;
    text-decoration: none;
    white-space: nowrap;
  }
  .va-look-all:hover { text-decoration: underline; }

  .va-look-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .va-look-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s;
  }
  .va-look-card:hover { transform: translateY(-4px); }

  .va-look-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 14px;
    overflow: hidden;
    background: #ede9e2;
    margin-bottom: 12px;
  }
  .va-look-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .va-look-card:hover .va-look-img { transform: scale(1.04); }

  .va-look-cart-btn {
    position: absolute;
    bottom: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(6px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    color: #333;
    transition: background 0.2s, color 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .va-look-cart-btn:hover { background: #FF7A42; color: #fff; }

  .va-look-card-title {
    font-size: 14px;
    font-weight: 700;
    color: #1a201c;
    margin: 0 0 4px;
    line-height: 1.3;
  }
  .va-look-card-price {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #555;
  }

  @media (max-width: 700px) {
    .va-look-inner { padding: 24px 20px 0; }
    .va-look-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .va-look-titles h2 { font-size: 20px; }
    .va-look-header { flex-direction: column; align-items: flex-start; }
  }
</style>

<div class="va-look-section">
  <div class="va-look-inner">

    <div class="va-look-header">
      <div class="va-look-titles">
        <h2>Perfect Pairings</h2>
        <p>Elevate every walk with these premium, hand-picked additions.</p>
      </div>
      <a href="/collections/all" class="va-look-all">View Entire Collection &rarr;</a>
    </div>

    <div class="va-look-grid" id="va-look-grid">

      {% comment %} FALLBACK: Find ANY collection that has products {% endcomment %}
      {% assign fallback_products = nil %}
      {% for c in collections %}
        {% if c.products.size > 0 %}
          {% assign fallback_products = c.products %}
          {% break %}
        {% endif %}
      {% endfor %}
      {% assign count = 0 %}
      {% for p in fallback_products %}
        {% unless p.id == product.id %}
          {% if count < 3 %}
            <a href="{{ p.url }}" class="va-look-card">
              <div class="va-look-img-wrap">
                <img class="va-look-img"
                     src="{{ p.featured_image | img_url: '600x600', crop: 'center' }}"
                     alt="{{ p.title | escape }}"
                     loading="lazy">
                <button class="va-look-cart-btn"
                        onclick="vaQuickAdd(event, '{{ p.variants.first.id }}')"
                        title="Quick add">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                  </svg>
                </button>
              </div>
              <div class="va-look-card-title">{{ p.title }}</div>
              <div class="va-look-card-price">{{ p.price | money }}</div>
            </a>
            {% assign count = count | plus: 1 %}
          {% endif %}
        {% endunless %}
      {% endfor %}

    </div>
  </div>
</div>

<script>
  function vaQuickAdd(e, variantId) {
    e.preventDefault();
    e.stopPropagation();
    const btn = e.currentTarget;
    btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';
    btn.style.background = '#4A5D4E';
    btn.style.color = '#fff';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(r => r.json())
    .then(() => {
      if (typeof openCartDrawer === 'function') openCartDrawer();
      setTimeout(() => {
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>';
        btn.style.background = 'rgba(255,255,255,0.92)';
        btn.style.color = '#333';
      }, 1500);
    })
    .catch(() => {});
  }
</script>

{% schema %}
{
  "name": "Complete the Look",
  "settings": []
}
{% endschema %}
