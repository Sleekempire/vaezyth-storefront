{% unless template.name == 'index' %}
<header class="site-header" style="position: relative; z-index: 999; padding: 20px 48px; display: flex; justify-content: space-between; align-items: center; background: #1c1917; border-bottom: 1px solid rgba(255,255,255,0.1);">
  {% render 'header-content' %}
</header>
{% endunless %}




{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "label": "Custom logo height",
      "min": 20,
      "max": 120,
      "step": 5,
      "default": 40,
      "unit": "px"
    }
  ]
}
{% endschema %}
