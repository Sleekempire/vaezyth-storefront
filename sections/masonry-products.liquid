<div class="app-container" style="padding-top: 80px; padding-bottom: 80px;">
  <div class="masonry-header" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px;">
    <h2 style="font-family: 'Outfit', serif; font-size: 48px; font-weight: normal; color: #131110; margin: 0; letter-spacing: -1px;">
      {{ section.settings.title }}
    </h2>
    <a href="{{ collections[section.settings.collection].url }}" style="background: transparent; border: 1px solid #ddd; padding: 10px 24px; border-radius: 50px; font-size: 11px; font-weight: 700; cursor: pointer; text-decoration: none; color: #131110; display: inline-flex; align-items: center; gap: 8px;">
      SHOP COLLECTION
      <span style="background: #131110; color: #fff; width: 20px; height: 20px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 10px;">↗</span>
    </a>
  </div>

  {% assign target_collection = collections[section.settings.collection] %}
  {% assign products = target_collection.products | default: (1..3) %}

  <div class="masonry-grid" style="display: flex; gap: 24px; align-items: flex-end;">
    <!-- Left Column: Tall -->
    <div class="masonry-col" style="flex: 1.2;">
      <a href="{{ products[0].url | default: '#' }}" class="masonry-card" style="display: block; position: relative; height: 600px; border-radius: 24px; overflow: hidden; text-decoration: none;">
        <img src="{{ products[0].featured_image | img_url: 'master' | default: 'https://via.placeholder.com/600x800' }}" alt="{{ products[0].title | default: 'Product 1' }}" style="width: 100%; height: 100%; object-fit: cover;" />
        <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(to bottom, rgba(0,0,0,0) 50%, rgba(0,0,0,0.6) 100%);"></div>
        
        <div style="position: absolute; top: 32px; left: 32px; color: #fff;">
          <p style="font-size: 12px; font-weight: bold; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px;">Explore Collections</p>
          <p style="font-size: 12px; opacity: 0.7;">21/05/25</p>
        </div>

        <div style="position: absolute; bottom: 24px; left: 24px; right: 24px; background: rgba(255,255,255,0.1); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.2); border-radius: 24px; padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; color: #fff;">
          <div>
            <h4 style="font-family: 'Outfit', sans-serif; font-size: 18px; margin-bottom: 4px; font-weight: 600;">{{ products[0].title | default: 'Table Lamps' }}</h4>
            <p style="font-size: 12px; color: rgba(255,255,255,0.7);">Price - {{ products[0].price | money | default: '$49.99' }}</p>
          </div>
          <div style="width: 36px; height: 36px; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #131110;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
          </div>
        </div>
      </a>
    </div>

    <!-- Middle Column: Medium -->
    <div class="masonry-col" style="flex: 1; display: flex; flex-direction: column;">
      <div style="margin-bottom: 24px; padding: 0 16px;">
        <p style="font-size: 10px; font-weight: bold; color: #C5A880; letter-spacing: 1px; margin-bottom: 8px;">EST 2010</p>
        <p style="font-size: 12px; color: #666; line-height: 1.6;">Our collection of modern, timeless, and smart pet gear is designed to add warmth, comfort, and beauty to your home.</p>
      </div>
      <a href="{{ products[1].url | default: '#' }}" class="masonry-card" style="display: block; position: relative; height: 440px; border-radius: 24px; overflow: hidden; text-decoration: none;">
        <img src="{{ products[1].featured_image | img_url: 'master' | default: 'https://via.placeholder.com/600x600' }}" alt="{{ products[1].title | default: 'Product 2' }}" style="width: 100%; height: 100%; object-fit: cover;" />
        <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(to bottom, rgba(0,0,0,0) 50%, rgba(0,0,0,0.6) 100%);"></div>

        <div style="position: absolute; bottom: 24px; left: 24px; right: 24px; background: rgba(255,255,255,0.1); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.2); border-radius: 24px; padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; color: #fff;">
          <div>
            <h4 style="font-family: 'Outfit', sans-serif; font-size: 18px; margin-bottom: 4px; font-weight: 600;">{{ products[1].title | default: 'Floor Lamps' }}</h4>
            <p style="font-size: 12px; color: rgba(255,255,255,0.7);">Price - {{ products[1].price | money | default: '$49.99' }}</p>
          </div>
          <div style="width: 36px; height: 36px; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #131110;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
          </div>
        </div>
      </a>
    </div>

    <!-- Right Column: Small -->
    <div class="masonry-col" style="flex: 1; display: flex; flex-direction: column;">
      <div style="display: flex; gap: 8px; justify-content: center; margin-bottom: 24px;">
        <button style="width: 32px; height: 32px; border-radius: 50%; border: 1px solid #ddd; background: #fff; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #666;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button style="width: 32px; height: 32px; border-radius: 50%; border: none; background: #C5A880; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #fff;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
      <a href="{{ products[2].url | default: '#' }}" class="masonry-card" style="display: block; position: relative; height: 280px; border-radius: 24px; overflow: hidden; text-decoration: none;">
        <img src="{{ products[2].featured_image | img_url: 'master' | default: 'https://via.placeholder.com/600x400' }}" alt="{{ products[2].title | default: 'Product 3' }}" style="width: 100%; height: 100%; object-fit: cover;" />
        <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(to bottom, rgba(0,0,0,0) 50%, rgba(0,0,0,0.6) 100%);"></div>

        <div style="position: absolute; bottom: 24px; left: 24px; right: 24px; background: rgba(255,255,255,0.1); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.2); border-radius: 24px; padding: 12px 16px; display: flex; justify-content: space-between; align-items: center; color: #fff;">
          <div>
            <h4 style="font-family: 'Outfit', sans-serif; font-size: 16px; margin-bottom: 2px; font-weight: 600;">{{ products[2].title | default: 'Outdoor Lamps' }}</h4>
            <p style="font-size: 11px; color: rgba(255,255,255,0.7);">Price - {{ products[2].price | money | default: '$49.99' }}</p>
          </div>
          <div style="width: 32px; height: 32px; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #131110;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
          </div>
        </div>
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Masonry Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Masonry Products Grid"
    }
  ]
}
{% endschema %}
