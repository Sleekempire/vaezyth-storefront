{% assign products = collections[section.settings.collection].products %}

<style>
  .cf-section {
    padding: 48px 0 56px;
    background: #f5f1ec;
  }
  .cf-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .cf-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 28px;
  }
  .cf-header-left {}
  .cf-label {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #999;
    margin: 0 0 4px;
  }
  .cf-title {
    font-family: 'Outfit', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
  }
  .cf-shop-link {
    font-size: 13px;
    font-weight: 600;
    color: #4A6741;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap 0.2s;
  }
  .cf-shop-link:hover { gap: 10px; }

  /* Carousel Viewport */
  .cf-viewport { overflow: hidden; }
  .cf-track {
    display: flex;
    gap: 16px;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* Product Card */
  .cf-card {
    flex: 0 0 calc(25% - 12px);
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    position: relative;
  }
  .cf-card:hover {
    box-shadow: 0 12px 36px rgba(0,0,0,0.10);
    transform: translateY(-3px);
  }
  .cf-card-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f0ece6;
  }
  .cf-card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .cf-card:hover .cf-card-img-wrap img { transform: scale(1.05); }
  .cf-card-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #fff;
    color: #1a1a1a;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 50px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.10);
    z-index: 2;
  }
  .cf-card-badge.new { background: #c8e6c9; color: #2e7d32; }
  .cf-card-badge.bestseller { background: #fff3cd; color: #856404; }
  .cf-card-badge.pick { background: #e3f2fd; color: #1565c0; }
  .cf-wishlist-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 30px;
    height: 30px;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(6px);
    border-radius: 50%;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    color: #999;
    transition: color 0.2s, transform 0.2s;
  }
  .cf-wishlist-btn:hover { color: #e53935; transform: scale(1.15); }

  .cf-card-body {
    padding: 14px 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }
  .cf-card-rating {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    color: #8C7A5D;
    font-weight: 500;
  }
  .cf-card-rating .stars { color: #8C7A5D; font-size: 12px; }
  .cf-card-title {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .cf-card-price {
    font-family: 'Outfit', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: #8C7A5D;
    margin: 4px 0 0;
  }
  .cf-atc-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    width: 100%;
    margin-top: 10px;
    padding: 10px 0;
    border: 1.5px solid #e0dbd4;
    border-radius: 8px;
    background: #fff;
    color: #1a1a1a;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    text-decoration: none;
  }
  .cf-atc-btn:hover {
    background: #1a1a1a;
    border-color: #1a1a1a;
    color: #fff;
  }

  /* Nav arrows below header */
  .cf-nav {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .cf-nav-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid #ccc;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #555;
    transition: all 0.2s;
    flex-shrink: 0;
  }
  .cf-nav-btn:hover, .cf-nav-btn.active { background: #4A6741; border-color: #4A6741; color: #fff; }

  @media (max-width: 900px) {
    .cf-section { padding: 32px 0 40px; }
    .cf-inner { padding: 0 16px; }
    .cf-title { font-size: 20px; }
    .cf-card { flex: 0 0 calc(72vw - 16px); }
    .cf-card-title { font-size: 13px; }
    .cf-card-price { font-size: 15px; }
  }
  @media (max-width: 480px) {
    .cf-card { flex: 0 0 calc(85vw - 16px); }
  }
</style>

<section class="cf-section">
  <div class="cf-inner">

    <div class="cf-header">
      <div class="cf-header-left">
        <p class="cf-label">Curated for You</p>
        <h2 class="cf-title">{{ section.settings.title }}</h2>
      </div>
      <div style="display:flex; align-items:center; gap:16px;">
        <a href="{{ collections[section.settings.collection].url }}" class="cf-shop-link">
          Shop All Products
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <div class="cf-nav">
          <button class="cf-nav-btn" id="cf-prev" onclick="cfScroll(-1)" aria-label="Previous">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button class="cf-nav-btn active" id="cf-next" onclick="cfScroll(1)" aria-label="Next">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="cf-viewport" id="cf-viewport">
      <div class="cf-track" id="cf-track">
        {% assign badge_types = "bestseller,new,pick,bestseller,new,pick,bestseller,new,pick" | split: "," %}
        {% assign badge_labels = "Best Seller,New,Staff Pick,Best Seller,New,Staff Pick,Best Seller,New,Staff Pick" | split: "," %}
        {% assign ratings_list = "4.9 (130),4.8 (98),4.7 (74),4.9 (112),4.8 (63),4.7 (89),4.9 (55),4.8 (77),4.7 (41)" | split: "," %}

        {% for product in products limit: 9 %}
          {% assign bi = forloop.index0 | modulo: 3 %}
          {% assign btype = badge_types[bi] %}
          {% assign blabel = badge_labels[bi] %}
          {% assign rating_str = ratings_list[bi] %}
          <div class="cf-card">
            <div class="cf-card-img-wrap">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title | escape }}" loading="lazy" />
              {% endif %}
              <span class="cf-card-badge {{ btype }}">{{ blabel }}</span>
              <button class="cf-wishlist-btn" aria-label="Wishlist">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              </button>
            </div>
            <div class="cf-card-body">
              <div class="cf-card-rating">
                <span class="stars">★</span> {{ rating_str }}
              </div>
              <h3 class="cf-card-title">{{ product.title }}</h3>
              <div class="cf-card-price">{{ product.price | money }}</div>
              <button class="cf-atc-btn" onclick="cfAddToCart('{{ product.variants.first.id }}', this)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Add to Cart
              </button>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

<script>
(function() {
  var idx = 0;
  var perView = 4;

  function cards() { return document.querySelectorAll('#cf-track .cf-card'); }
  function cardW() {
    var c = cards()[0];
    if (!c) return 0;
    return c.offsetWidth + 16;
  }
  function maxIdx() { return Math.max(0, cards().length - perView); }

  function update() {
    document.getElementById('cf-track').style.transform = 'translateX(-' + (idx * cardW()) + 'px)';
    document.getElementById('cf-prev').classList.toggle('active', idx > 0);
    document.getElementById('cf-next').classList.toggle('active', idx < maxIdx());
  }

  window.cfScroll = function(dir) {
    idx = Math.max(0, Math.min(idx + dir, maxIdx()));
    update();
  };

  function responsive() {
    var w = window.innerWidth;
    perView = w < 480 ? 1 : w < 900 ? 2 : 4;
    idx = Math.min(idx, maxIdx());
    update();
  }

  window.addEventListener('resize', responsive);
  responsive();
})();

function cfAddToCart(variantId, btn) {
  var orig = btn.innerHTML;
  btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Added!';
  btn.style.background = '#4A6741';
  btn.style.color = '#fff';
  btn.style.borderColor = '#4A6741';
  fetch('/cart/add.js', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({id: variantId, quantity: 1})
  }).then(function() {
    var cc = document.querySelector('.cart-count');
    if (cc) cc.textContent = parseInt(cc.textContent || 0) + 1;
    setTimeout(function() {
      btn.innerHTML = orig;
      btn.style.background = '';
      btn.style.color = '';
      btn.style.borderColor = '';
    }, 2000);
  });
}
</script>

{% schema %}
{
  "name": "Best Sellers Carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Best Sellers Carousel"
    }
  ]
}
{% endschema %}
