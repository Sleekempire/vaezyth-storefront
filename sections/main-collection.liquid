<div class="app-container" style="padding-top: 60px; padding-bottom: 80px;">
  <div class="collection-header" style="text-align: center; margin-bottom: 60px;">
    <h1 style="font-family: 'Outfit', sans-serif; font-size: 48px; font-weight: 800; color: #131110; margin-bottom: 16px;">
      {{ collection.title | default: 'All Products' }}
    </h1>
    {% if collection.description != blank %}
      <div style="font-size: 16px; color: #666; max-width: 600px; margin: 0 auto; line-height: 1.6;">
        {{ collection.description }}
      </div>
    {% endif %}
  </div>

  <div class="products-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;">
    {% paginate collection.products by 24 %}
      {% for product in collection.products %}
        <div class="product-card luxury-card" style="background: #ffffff; color: #131110; border-radius: 16px; padding: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); transition: transform 0.3s ease, box-shadow 0.3s ease; display: flex; flex-direction: column; height: 100%;">
          <a href="{{ product.url }}" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%;">
            <div class="luxury-card-media" style="background: #ffffff; border-radius: 12px; height: 220px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; overflow: hidden;">
              <img src="{{ product.featured_image | img_url: 'large' }}" alt="{{ product.title | escape }}" style="max-height: 100%; max-width: 100%; object-fit: contain; mix-blend-mode: multiply;" />
            </div>
            <div class="product-card-title" style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 14px; font-weight: 700; color: #131110; margin-bottom: 12px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{{ product.title }}</div>
            <div class="product-card-price-row" style="margin-top: auto; display: flex; align-items: baseline; gap: 8px;">
              <span class="product-card-price" style="font-family: 'Outfit', sans-serif; font-size: 18px; font-weight: 800; color: #131110;">{{ product.price | money }}</span>
              {% if product.compare_at_price > product.price %}
                <span style="font-size: 12px; text-decoration: line-through; color: #999;">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </div>
          </a>
        </div>
      {% else %}
        <div style="grid-column: 1 / -1; text-align: center; padding: 60px 0; color: #666;">
          <p>There are no products in this collection yet.</p>
        </div>
      {% endfor %}
      
      {% if paginate.pages > 1 %}
        <div class="pagination" style="grid-column: 1 / -1; display: flex; justify-content: center; gap: 12px; margin-top: 40px;">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</div>

{% schema %}
{
  "name": "Collection Grid",
  "settings": []
}
{% endschema %}
