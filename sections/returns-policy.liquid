<style>
  .rp-wrap {
    background: #faf8f4;
    padding: 60px 5% 80px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #1a201c;
  }
  .rp-inner {
    max-width: 780px;
    margin: 0 auto;
  }
  .rp-badge {
    display: inline-block;
    background: #4A5D4E;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 50px;
    margin-bottom: 20px;
  }
  .rp-title {
    font-family: 'Outfit', sans-serif;
    font-size: 38px;
    font-weight: 700;
    color: #1a201c;
    margin: 0 0 12px;
    line-height: 1.2;
  }
  .rp-subtitle {
    font-size: 15px;
    color: #777;
    line-height: 1.6;
    margin-bottom: 40px;
    max-width: 560px;
  }

  /* Policy Sections */
  .rp-section {
    margin-bottom: 36px;
    padding-bottom: 36px;
    border-bottom: 1px solid #e8e3da;
  }
  .rp-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .rp-section-title {
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #1a201c;
    margin: 0 0 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .rp-section-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: #f0eee9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4A5D4E;
    flex-shrink: 0;
  }
  .rp-text {
    font-size: 14px;
    line-height: 1.8;
    color: #555;
  }
  .rp-text ul {
    padding-left: 20px;
    margin: 12px 0;
  }
  .rp-text li {
    margin-bottom: 8px;
  }
  .rp-text strong {
    color: #1a201c;
  }

  /* Highlight Box */
  .rp-highlight {
    background: #f0eee9;
    border-radius: 12px;
    padding: 24px 28px;
    margin-top: 16px;
    border-left: 4px solid #4A5D4E;
  }
  .rp-highlight p {
    margin: 0;
    font-size: 14px;
    color: #444;
    line-height: 1.7;
  }

  /* CTA */
  .rp-cta {
    text-align: center;
    margin-top: 48px;
    padding: 40px;
    background: #1c1917;
    border-radius: 16px;
    color: #fff;
  }
  .rp-cta h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 22px;
    font-weight: 700;
    margin: 0 0 8px;
  }
  .rp-cta p {
    font-size: 14px;
    color: #aaa;
    margin: 0 0 20px;
  }
  .rp-cta a {
    display: inline-block;
    background: #4A5D4E;
    color: #fff;
    padding: 12px 32px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .rp-cta a:hover { opacity: 0.85; }

  @media (max-width: 600px) {
    .rp-wrap { padding: 40px 5% 60px; }
    .rp-title { font-size: 28px; }
    .rp-cta { padding: 28px 20px; }
    .rp-cta h3 { font-size: 18px; }
  }
</style>

<div class="rp-wrap">
  <div class="rp-inner">

    <span class="rp-badge">Our Promise</span>
    <h1 class="rp-title">Returns & Refund Policy</h1>
    <p class="rp-subtitle">Your satisfaction is our priority. We want you and your companion to love every Vaezyth product.</p>

    <!-- Section 1: Eligibility -->
    <div class="rp-section">
      <h2 class="rp-section-title">
        <span class="rp-section-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        Return Eligibility
      </h2>
      <div class="rp-text">
        <p>We offer a <strong>30-day money-back guarantee</strong> from the date of delivery. To qualify for a return, your item must be:</p>
        <ul>
          <li>Unused and in its original condition</li>
          <li>In the original packaging with all tags attached</li>
          <li>Accompanied by proof of purchase (order number or receipt)</li>
        </ul>
      </div>
    </div>

    <!-- Section 2: How to Return -->
    <div class="rp-section">
      <h2 class="rp-section-title">
        <span class="rp-section-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/><path d="M12 12v9"/><path d="m8 17 4 4 4-4"/></svg>
        </span>
        How to Initiate a Return
      </h2>
      <div class="rp-text">
        <p>Starting a return is simple:</p>
        <ul>
          <li><strong>Step 1:</strong> Email us at <a href="mailto:support@vaezyth.com" style="color:#4A5D4E; text-decoration:underline;">support@vaezyth.com</a> with your order number and reason for the return.</li>
          <li><strong>Step 2:</strong> Our team will respond within 24 hours with a return shipping label and instructions.</li>
          <li><strong>Step 3:</strong> Pack your item securely and drop it off at the designated carrier.</li>
        </ul>
      </div>
    </div>

    <!-- Section 3: Refunds -->
    <div class="rp-section">
      <h2 class="rp-section-title">
        <span class="rp-section-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </span>
        Refund Processing
      </h2>
      <div class="rp-text">
        <p>Once we receive and inspect your return:</p>
        <ul>
          <li>Refunds are processed within <strong>3–5 business days</strong> to your original payment method.</li>
          <li>You will receive an email confirmation once your refund has been issued.</li>
          <li>Please allow an additional 5–10 business days for the refund to appear on your statement, depending on your bank.</li>
        </ul>
        <div class="rp-highlight">
          <p><strong>Please note:</strong> Shipping costs are non-refundable. If the return is due to our error (wrong item, defective product), we will cover return shipping costs.</p>
        </div>
      </div>
    </div>

    <!-- Section 4: Exchanges -->
    <div class="rp-section">
      <h2 class="rp-section-title">
        <span class="rp-section-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
        </span>
        Exchanges
      </h2>
      <div class="rp-text">
        <p>We are happy to exchange your item for a different size or colour at no additional cost (subject to availability). Simply contact us and we will arrange the exchange promptly.</p>
      </div>
    </div>

    <!-- Section 5: Non-Returnable Items -->
    <div class="rp-section">
      <h2 class="rp-section-title">
        <span class="rp-section-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
        </span>
        Non-Returnable Items
      </h2>
      <div class="rp-text">
        <p>For hygiene and safety reasons, the following items cannot be returned:</p>
        <ul>
          <li>Items that have been used, washed, or altered</li>
          <li>Gift cards</li>
          <li>Items purchased during final sale promotions</li>
        </ul>
      </div>
    </div>

    <!-- CTA -->
    <div class="rp-cta">
      <h3>Still have questions?</h3>
      <p>Our support team is here to help with any concerns.</p>
      <a href="mailto:support@vaezyth.com">Contact Support</a>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Returns Policy",
  "settings": []
}
{% endschema %}
